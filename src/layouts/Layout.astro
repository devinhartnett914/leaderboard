---
import { isSupabaseConfigured } from '../lib/supabase';

interface Props {
	title?: string;
	subtitle?: string;
	avatarUrl?: string | null;
}
const { title = 'Tri•Me', subtitle, avatarUrl } = Astro.props;
const fullTitle = title === 'Tri•Me' ? 'Tri•Me — family race results' : `${title} · Tri•Me`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;600;700&family=Inter+Tight:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
	</head>
	<body>
		<header class="site-header">
			<nav class="container">
				<a href="/" class="brand">🏁 Tri•Me</a>
				<div class="nav-links">
					<a href="/">Home</a>
					<a href="/races">Races</a>
					<a href="/admin">Add results</a>
				</div>
			</nav>
		</header>

		{
			!isSupabaseConfigured && (
				<div class="setup-banner">
					<div class="container">
						<strong>Setup needed:</strong> connect a Supabase project to load data. Add{' '}
						<code>PUBLIC_SUPABASE_URL</code> and <code>PUBLIC_SUPABASE_ANON_KEY</code> to a{' '}
						<code>.env</code> file (see <code>.env.example</code>), then restart the dev server.
					</div>
				</div>
			)
		}

		<main class="container">
			{(title !== 'Tri•Me' || subtitle) && (
				<div class="page-head">
					{avatarUrl && <img class="page-avatar" src={avatarUrl} alt={title} />}
					<div class="page-head-text">
						<h1>{title}</h1>
						{subtitle && <p class="subtitle">{subtitle}</p>}
					</div>
				</div>
			)}
			<slot />
		</main>

		<style is:global>
			/* Subtle cross-document view transition for browsers that support it
			   (Chromium 126+). Firefox/Safari ignore this rule, so the entrance
			   fade below covers fallback. No JS, no SPA — pages stay SSR. */
			@view-transition { navigation: auto; }

			:root {
				/* palette adapted from the "Monday Swim" app: deep navy + electric cyan + mint */
				--bg: #0a1628;
				--bg-2: #0f2038;
				--surface: #14294a;
				--surface-2: #1a3358;
				--text: #eaf2ff;
				--muted: #a6b9d6;
				--faint: #8194b6;
				--accent: #00d4ff;
				--accent-2: #7df9ff;
				--accent-soft: rgba(0, 212, 255, 0.1);
				--faster: #29e3a4;
				--slower: #ff6b9d;
				--gold: #ffcf5c;
				/* discipline accents */
				--swim: #00d4ff;
				--bike: #ffb86b;
				--run: #29e3a4;
				--border: rgba(255, 255, 255, 0.08);
				--line-strong: rgba(255, 255, 255, 0.18);
				--radius: 14px;
				--shadow: 0 14px 40px rgba(0, 0, 0, 0.4);
				--font-display: 'Bebas Neue', sans-serif;
				--font-mono: 'JetBrains Mono', ui-monospace, monospace;
				--font-body: 'Inter Tight', system-ui, -apple-system, sans-serif;
				--maxw: 1040px;
			}

			* { box-sizing: border-box; }

			html { color-scheme: dark; }

			body {
				margin: 0;
				font-family: var(--font-body);
				background-color: var(--bg);
				background-image: radial-gradient(1200px 600px at 50% -10%, rgba(0, 212, 255, 0.12), transparent 60%),
					linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
				background-attachment: fixed;
				color: var(--text);
				line-height: 1.5;
				-webkit-font-smoothing: antialiased;
			}

			.container { width: 100%; max-width: var(--maxw); margin: 0 auto; padding: 0 1.25rem; }

			a { color: var(--accent); text-decoration: none; }
			a:hover { text-decoration: underline; }

			.site-header {
				border-bottom: 1px solid var(--border);
				background: rgba(15, 20, 25, 0.85);
				backdrop-filter: blur(8px);
				position: sticky;
				top: 0;
				z-index: 10;
			}
			.site-header nav {
				display: flex;
				align-items: center;
				justify-content: space-between;
				height: 60px;
			}
			.brand { font-family: var(--font-display); font-weight: 400; font-size: 1.7rem; letter-spacing: 0.06em; color: var(--text); }
			.brand:hover { text-decoration: none; color: var(--accent); }
			.nav-links { display: flex; gap: 1.5rem; }
			.nav-links a { font-family: var(--font-mono); color: var(--muted); font-weight: 500; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; }
			.nav-links a:hover { color: var(--text); text-decoration: none; }

			.setup-banner {
				background: var(--accent-soft);
				border-bottom: 1px solid var(--border);
				padding: 0.7rem 0;
				font-size: 0.9rem;
				color: var(--text);
			}
			.setup-banner code {
				background: #00000040;
				padding: 0.1rem 0.35rem;
				border-radius: 5px;
				font-size: 0.85em;
			}

			main { padding: 2rem 0 3rem; min-height: 60vh; }
			/* Tasteful entrance: each page softly settles in. Skipped for users
			   who prefer reduced motion. Browsers running the @view-transition
			   above will already cross-fade the document — this animation runs
			   in parallel and stays subtle enough not to compete. */
			main { animation: page-enter 180ms ease-out both; }
			@keyframes page-enter {
				from { opacity: 0; transform: translateY(4px); }
				to { opacity: 1; transform: translateY(0); }
			}
			@media (prefers-reduced-motion: reduce) {
				main { animation: none; }
			}

			.page-head { display: flex; align-items: center; gap: 1.4rem; margin-bottom: 1.75rem; }
			.page-avatar { width: 96px; height: 96px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: 3px solid var(--surface-2); box-shadow: var(--shadow), 0 0 0 1px var(--border); }
			.page-head h1 { margin: 0; font-family: var(--font-display); font-weight: 400; font-size: 3.1rem; letter-spacing: 0.02em; line-height: 0.95; }
			.subtitle { margin: 0.5rem 0 0; font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); }

			/* Shared shell for the three feed cards (ResultRow / MeetCard /
			   RaceGroupCard) — full-width subgrid box with the category edge
			   accent on the left. The card sets `--edge` on itself and the
			   border-left reads it. Defined globally so all three components
			   stay in lockstep on radius / shadow / gradient. */
			.feed-card {
				grid-column: 1 / -1;
				display: grid;
				grid-template-columns: subgrid;
				align-items: stretch;
				background: linear-gradient(180deg, var(--surface-2), var(--surface) 90px);
				border: 1px solid var(--border);
				border-left: 3px solid var(--edge);
				border-radius: 14px;
				box-shadow: var(--shadow);
				overflow: hidden;
			}

			.card {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 1.25rem;
				box-shadow: var(--shadow);
			}

			.grid { display: grid; gap: 1rem; }
			.grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
			.grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
			@media (max-width: 720px) {
				.grid.cols-2, .grid.cols-3 { grid-template-columns: 1fr; }
			}

			.muted { color: var(--muted); }
			.pill {
				display: inline-block;
				font-size: 0.75rem;
				font-weight: 600;
				padding: 0.15rem 0.55rem;
				border-radius: 999px;
				background: var(--surface-2);
				color: var(--muted);
				border: 1px solid var(--border);
			}
			.pill.gold { background: #3a2f00; color: var(--gold); border-color: #5c4a00; }

			table { width: 100%; border-collapse: collapse; }
			th, td { text-align: left; padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--border); }
			th { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--muted); font-weight: 600; }
			td { font-variant-numeric: tabular-nums; }
			tr:last-child td { border-bottom: none; }

			.delta.faster { color: var(--faster); }
			.delta.slower { color: var(--slower); }
			.delta.same { color: var(--muted); }

			.empty {
				text-align: center;
				color: var(--muted);
				padding: 3rem 1rem;
				border: 1px dashed var(--border);
				border-radius: var(--radius);
			}
		</style>
	</body>
</html>
