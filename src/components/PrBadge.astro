---
// Personal-record marker: gold star + "PR" caption. Glyph + caption sizing is kept
// identical to PodiumMedal (.mk-glyph / .mk-cap) so the two never look like different
// fonts when they sit side by side to the left of a time.
---
<span class="prbadge">
	<span class="mk-glyph">⭐</span>
	<span class="mk-cap">PR</span>
</span>

<style>
	.prbadge { display: inline-flex; flex-direction: column; align-items: center; gap: 0.1rem; line-height: 1; vertical-align: middle; }
	.mk-glyph { font-size: 1.1rem; line-height: 1; }
	.mk-cap { font-family: var(--font-mono); font-size: var(--fs-cap); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); white-space: nowrap; }
</style>
