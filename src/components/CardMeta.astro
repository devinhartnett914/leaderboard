---
// The "type · distance · event" mono-uppercase strip that sits just BELOW the
// RaceTitle on every card (ResultRow, MeetCard, RaceGroupCard, RecentCard). Each
// piece is optional. The strip reads `--edge` from the parent card so its color
// always matches the card's left-edge accent. The category ICON leads the strip
// (when `catKey` is given) — this is THE place the sport icon appears on a card, so
// it rides with the race TYPE rather than the race name.
import { catIcon } from '../lib/categories';
interface Props {
	type: string;
	catKey?: string | null;
	distance?: string | null;
	event?: string | null;
	location?: string | null;
}
const { type, catKey = null, distance = null, event = null, location = null } = Astro.props;
---
<span class="cardmeta">
	{catKey && <span class="cm-ic">{catIcon(catKey)}</span>}
	<span class="cm-type">{type}</span>
	{distance && <span class="cm-dist">· {distance}</span>}
	{location && <span class="cm-loc">· {location}</span>}
	{event && <span class="cm-ev">· {event}</span>}
</span>

<style>
	/* mono-uppercase strip — inherits the card's --edge color so the icon, type
	   tag, distance, and (optional) swim event read in one consistent voice. */
	.cardmeta { flex-shrink: 0; display: inline-flex; align-items: baseline; gap: 0.35rem; font-family: var(--font-mono); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; white-space: nowrap; }
	/* icon centered against the small caps, sized up so the glyph reads clearly. It is a
	   native COLOR emoji (the emoji font stack keeps it from falling back to a tinted mono
	   glyph), so it is NOT colored by --edge — e.g. the Sprint ⚡ stays orange on a purple tri. */
	.cm-ic { align-self: center; flex-shrink: 0; font-size: 0.95rem; line-height: 1; font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', emoji; }
	/* type, distance, and location all read in the card's --edge (category) color — the
	   same "type · location" treatment the race-page header uses (DEV-30). */
	.cm-type, .cm-dist, .cm-loc { color: var(--edge); }
	.cm-ev { color: var(--faint); }
</style>
