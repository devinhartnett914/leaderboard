---
// One swim meet, grouped — shared by the person page and the all-races feed. Lives in
// the parent `.results` subgrid; event times line up with the tri/run finish column.
import ResultMarks from './ResultMarks.astro';
import RaceTitle from './RaceTitle.astro';
import PersonChip from './PersonChip.astro';
import { formatSwimTime, parseSwimEvent, swimEventSlug, ordinal, abbrevDivision, dateParts } from '../lib/format';
import { podiumPlace, swimCs, type MeetEntry, type PrContext } from '../lib/feed';

interface Props {
	entry: MeetEntry;
	prCtx: PrContext;
	showPerson?: boolean;
}
const { entry, prCtx, showPerson = false } = Astro.props;
const events = entry.events;
const ed = events[0].race_edition;
const person = events[0].person;
const dp = dateParts(ed?.date, ed?.year);
const year = Number(entry.date.slice(0, 4)) || ed?.year || '';
const places = [...new Set(events.map(podiumPlace).filter((p): p is number => p != null))].join(' ');
---
<article class="mcard" data-cat="swim_meet" data-place={places} data-pr={events.some((e) => prCtx.isSwimPr(e)) ? '1' : '0'} data-person={person?.id ?? ''} data-year={String(year)} style={`--edge:var(--swim); grid-template-rows: repeat(${1 + events.length}, auto)`}>
	<div class="mc-date">
		<span class="d-mon">{dp.mon}</span><span class="d-day">{dp.day || dp.year}</span><span class="d-yr">{dp.day ? dp.year : ''}</span>
	</div>
	<div class="mc-head">
		<div class="mc-toprow">
			{showPerson && person && (
				<Fragment>
					<PersonChip person={person} avatar={20} nameRem={0.62} />
					<span class="mc-pipe" aria-hidden="true">|</span>
				</Fragment>
			)}
			<span class="mc-type">Swim Meet</span>
		</div>
		<RaceTitle catKey="swim_meet" name={ed?.race?.name ?? 'Swim meet'} href={ed?.race ? `/races/${ed.race.slug}` : null} />
	</div>
	{events.map((e, i) => {
		const ev = parseSwimEvent(e.event);
		const place = podiumPlace(e);
		const pr = prCtx.isSwimPr(e);
		const dq = e.status !== 'finished';
		const row = 2 + i;
		return (
			<Fragment>
				<a class="mc-evname" href={`/swim/${swimEventSlug(e.event)}`} style={`grid-row:${row}; --c:${ev.color}`}>
					<span class="ev-ic">{ev.icon}</span><span class="ev-lbl">{ev.short}</span>
				</a>
				<div class="mc-evtime" style={`grid-row:${row}`}>
					<span class="ev-timewrap">
						<ResultMarks medalTier={place} medalSub={abbrevDivision(e.division)} pr={pr && !dq} compact />
						{dq ? (
							<span class="ev-dq">{e.status.toUpperCase()}</span>
						) : (
							<span class:list={['ev-t', { 'is-pr': pr }]}>{formatSwimTime(swimCs(e))}</span>
						)}
					</span>
				</div>
				<div class="mc-evplace" style={`grid-row:${row}`}>
					<span class="ev-ord">{e.division_place != null ? ordinal(e.division_place) : '—'}</span>
					{e.division && <span class="ev-heat">{abbrevDivision(e.division)}</span>}
				</div>
			</Fragment>
		);
	})}
</article>

<style>
	.mcard {
		grid-column: 1 / -1; display: grid; grid-template-columns: subgrid; align-items: stretch;
		background: linear-gradient(180deg, var(--surface-2), var(--surface) 90px);
		border: 1px solid var(--border); border-left: 3px solid var(--edge); border-radius: 14px; box-shadow: var(--shadow); overflow: hidden;
	}
	.mc-date { grid-column: 1; grid-row: 1 / -1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 0.7rem 0.4rem; background: color-mix(in srgb, var(--edge) 16%, var(--surface-2)); border-right: 1px solid var(--border); }
	.d-mon { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--edge); }
	.d-day { font-family: var(--font-display); font-weight: 400; font-size: 2.4rem; line-height: 0.85; }
	.d-yr { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.1em; color: var(--muted); }

	.mc-head { grid-column: 2 / -1; grid-row: 1; padding: 0.8rem 1.1rem 0.65rem; border-bottom: 1px solid var(--border); }
	/* top row: "Swim Meet", led by the swimmer's name (PersonChip) + pipe on the feed */
	.mc-toprow { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.34rem; min-width: 0; }
	.mc-pipe { flex-shrink: 0; color: var(--line-strong); font-family: var(--font-mono); font-size: 0.62rem; }
	.mc-type { flex-shrink: 0; font-family: var(--font-mono); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--swim); white-space: nowrap; }

	.mc-evname { grid-column: 2; display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 1.1rem; min-width: 0; color: var(--text); border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent); }
	.mc-evname:hover { color: var(--swim); text-decoration: none; }
	.mc-evname .ev-ic { font-size: 1.15rem; line-height: 1; }
	.mc-evname .ev-lbl { font-family: var(--font-mono); font-size: 0.82rem; letter-spacing: 0.03em; white-space: nowrap; text-decoration: underline; text-decoration-color: color-mix(in srgb, var(--swim) 45%, transparent); text-underline-offset: 3px; }
	.mc-evname:hover .ev-lbl { text-decoration-color: var(--swim); }
	.mc-evtime { grid-column: 3 / 5; position: relative; display: flex; align-items: center; padding: 0.4rem 1.1rem; border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent); }
	.ev-timewrap { position: relative; width: max-content; }
	.ev-t { font-family: var(--font-display); font-weight: 400; font-size: 1.5rem; letter-spacing: 0.02em; line-height: 1; white-space: nowrap; }
	.ev-t.is-pr { color: var(--gold); }
	.ev-dq { font-family: var(--font-display); font-weight: 400; font-size: 1.5rem; letter-spacing: 0.02em; line-height: 1; color: var(--slower); }
	.mc-evplace { grid-column: 5; display: flex; flex-direction: column; justify-content: center; padding: 0.4rem 1.2rem 0.4rem 1.1rem; border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent); }
	.mc-evplace .ev-ord { font-family: var(--font-mono); font-size: 0.84rem; font-weight: 600; }
	.mc-evplace .ev-heat { font-family: var(--font-mono); font-size: 0.56rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint); margin-top: 0.1rem; }
	.mc-head + .mc-evname, .mc-head + .mc-evname + .mc-evtime, .mc-head + .mc-evname + .mc-evtime + .mc-evplace { border-top: none; }
</style>
