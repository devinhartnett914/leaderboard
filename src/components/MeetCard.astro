---
// One swim meet, grouped — shared by the person page and the all-races feed. Lives in
// the parent `.results` subgrid; event times line up with the tri/run finish column.
import ResultMarks from './ResultMarks.astro';
import RaceTitle from './RaceTitle.astro';
import RacerBadge from './RacerBadge.astro';
import DateRail from './DateRail.astro';
import CardSubMeta from './CardSubMeta.astro';
import ResultPlaces from './ResultPlaces.astro';
import FinishTime from './FinishTime.astro';
import { formatSwimTime, parseSwimEvent, swimEventSlug, swimDivision } from '../lib/format';
import { podiumPlace, swimCs, type MeetEntry, type PrContext } from '../lib/feed';

interface Props {
	entry: MeetEntry;
	prCtx: PrContext;
	showPerson?: boolean;
	placesVariant?: 'current' | 'stack';
}
const { entry, prCtx, showPerson = false, placesVariant = 'stack' } = Astro.props;
const events = entry.events;
const ed = events[0].race_edition;
const person = events[0].person;
const year = Number(entry.date.slice(0, 4)) || ed?.year || '';
const places = [...new Set(events.map(podiumPlace).filter((p): p is number => p != null))].join(' ');
// On the combined feed the meet carries its person → show them on the meta line below the name.
const racers = showPerson && person ? [person] : [];
// On the all-races feed (showPerson), show the meet location on the meta line beside the type.
const location = showPerson ? (ed?.race?.location ?? null) : null;
---
<article class="mcard feed-card" data-cat="swim_meet" data-place={places} data-pr={events.some((e) => prCtx.isSwimPr(e)) ? '1' : '0'} data-person={person?.id ?? ''} data-year={String(year)} style={`--edge:var(--swim); grid-template-rows: repeat(${1 + events.length}, auto)`}>
	<DateRail date={ed?.date} year={ed?.year} />
	<div class="mc-head">
		{racers.length > 0 && <RacerBadge racers={racers} />}
		<RaceTitle catKey="swim_meet" name={ed?.race?.name ?? 'Swim meet'} href={ed?.race ? `/races/${ed.race.slug}` : null} />
		<CardSubMeta type="Swim Meet" catKey="swim_meet" location={location} />
	</div>
	{events.map((e, i) => {
		const ev = parseSwimEvent(e.event);
		const place = podiumPlace(e);
		const pr = prCtx.isSwimPr(e);
		const dq = e.status !== 'finished';
		const row = 2 + i;
		return (
			<Fragment>
				<a class="mc-evname" href={`/swim/${swimEventSlug(e.event)}${person?.slug ? `?who=${encodeURIComponent(person.slug)}` : ''}`} style={`grid-row:${row}; --c:${ev.color}`}>
					<span class="ev-ic">{ev.icon}</span><span class="ev-lbl">{ev.short}</span>
				</a>
				<div class="mc-evtime" style={`grid-row:${row}`}>
					<span class="ev-timewrap">
						<ResultMarks medalTier={place} medalSub={swimDivision(e.division)} pr={pr && !dq} compact />
						<FinishTime time={dq ? '' : formatSwimTime(swimCs(e))} status={e.status} pr={pr} />
					</span>
				</div>
				<div class="mc-evplace" style={`grid-row:${row}`}>
					<ResultPlaces overallPlace={e.overall_place} overallFieldSize={e.overall_field_size} division={e.division} divisionPlace={e.division_place} variant={placesVariant} />
				</div>
			</Fragment>
		);
	})}
</article>

<style>

	/* name on top, type·racer a consistent 0.4rem below it, then extra room (1rem) before
	   the event rows so the meta line doesn't crowd them. */
	.mc-head { grid-column: 2 / -1; grid-row: 1; display: flex; flex-direction: column; align-items: flex-start; gap: 0.4rem; padding: 0.8rem 1.1rem 1rem; border-bottom: 1px solid var(--border); }

	/* Event name reads in the RANK's text treatment (plain light mono, fs-value, no caps /
	   no wide tracking) so the eye scans cleanly across the row to the time + standing;
	   hover → the stroke color. Kept in sync with EventChip's table variant. */
	.mc-evname { grid-column: 2; display: flex; align-items: center; gap: 0.5rem; padding: 0.65rem 1.1rem; min-width: 0; color: var(--text); border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent); }
	.mc-evname:hover { color: var(--c); text-decoration: none; }
	.mc-evname .ev-ic { font-size: 1.15rem; line-height: 1; }
	.mc-evname .ev-lbl { font-family: var(--font-mono); font-size: var(--fs-value); white-space: nowrap; }
	/* extra vertical padding so a row's medal/PR mark (taller than the time line, vertically
	   centered) clears the hairline dividers instead of butting them (DEV-23). */
	.mc-evtime { grid-column: 3 / 5; position: relative; display: flex; align-items: center; padding: 0.65rem 1.1rem; border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent); }
	.ev-timewrap { position: relative; width: max-content; }
	.mc-evplace { grid-column: 5; display: flex; flex-direction: column; justify-content: center; padding: 0.65rem 1.2rem 0.65rem 1.1rem; border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent); }
	.mc-head + .mc-evname, .mc-head + .mc-evname + .mc-evtime, .mc-head + .mc-evname + .mc-evtime + .mc-evplace { border-top: none; }
</style>
