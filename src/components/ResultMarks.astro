---
// The left-of-time markers on a result row: podium medal (outer) + PR star (inner,
// nearest the time). They hug the time with no reserved empty slot — a PR-only row
// has the star tight against the time, a medal-only row has the medal tight against
// it. When both are present the PR sits nearest the time and the medal bumps left.
// Anchors to the nearest positioned ancestor (the time wrapper / time cell).
import PodiumMedal from './PodiumMedal.astro';
import PrBadge from './PrBadge.astro';
interface Props {
	medalTier?: number | null; // 1|2|3 for a podium, else null
	medalSub?: string | null; // caption under the medal (division / age group)
	pr?: boolean;
	compact?: boolean; // tighter gap for dense cards (swim age groups)
}
const { medalTier = null, medalSub = null, pr = false, compact = false } = Astro.props;
---
{(medalTier || pr) && (
	<span class:list={['marks', { compact }]}>
		{medalTier && <PodiumMedal tier={medalTier} sub={medalSub} />}
		{pr && <PrBadge />}
	</span>
)}

<style>
	/* medal — star — time, packed tight: only present markers render, so no row ever
	   leaves a hole where a marker it doesn't have would go. */
	.marks { position: absolute; right: 100%; top: 50%; transform: translateY(-50%); z-index: 3; display: flex; align-items: center; gap: 0.5rem; padding-right: 0.55rem; }
	.marks.compact { gap: 0.4rem; padding-right: 0.45rem; }
</style>
