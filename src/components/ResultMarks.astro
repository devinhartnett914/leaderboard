---
// The left-of-time markers on a result row: podium medal (outer) + PR star (inner,
// nearest the time). They hug the time with no reserved empty slot — a PR-only row
// has the star tight against the time, a medal-only row has the medal tight against
// it. When both are present the PR sits nearest the time and the medal bumps left.
// Anchors to the nearest positioned ancestor (the time wrapper / time cell).
import PodiumMedal from './PodiumMedal.astro';
import PrBadge from './PrBadge.astro';
interface Props {
	medalTier?: number | null; // 1|2|3 for a podium, else null
	medalSub?: string | null; // caption under the medal (division / age group)
	pr?: boolean;
	compact?: boolean; // tighter gap for dense cards (swim age groups)
	inline?: boolean; // render in normal flow before a left-aligned figure (teaser cards)
}
const { medalTier = null, medalSub = null, pr = false, compact = false, inline = false } = Astro.props;
---
{(medalTier || pr) && (
	<span class:list={['marks', { compact, inline }]}>
		{medalTier && <PodiumMedal tier={medalTier} sub={medalSub} />}
		{pr && <PrBadge />}
	</span>
)}

<style>
	/* medal — star — time, packed tight: only present markers render, so no row ever
	   leaves a hole where a marker it doesn't have would go. star ↔ time gap is ONE
	   value (0.5rem) everywhere — feed rows, swim rows, the PrTime header — so the PR
	   badge reads identically against every time. `compact` only tightens the
	   medal ↔ star gap for dense cards. */
	.marks { position: absolute; right: 100%; top: 50%; transform: translateY(-50%); z-index: 3; display: flex; align-items: center; gap: 0.5rem; padding-right: 0.5rem; }
	.marks.compact { gap: 0.4rem; }
	/* inline: the same marks laid out in flow, sitting just left of a left-aligned
	   figure (teaser card) rather than absolutely left of a right-aligned time cell.
	   The parent supplies the gap to the figure and the bottom alignment. */
	.marks.inline { position: static; right: auto; top: auto; transform: none; padding-right: 0; align-items: flex-end; }
</style>
