---
// THE one way to render a result's standings on the far-right of a race row. The shipped
// 'stack' layout is DIVISION-FIRST and label-free: the division rank leads with the place
// before the age-group ("5th · F40-44"), and the overall — when there is one — trails in a
// smaller muted subline ("150th of 663"). A non-award heat carries no rank, so it reads just
// "Non-Award"; with no division at all the overall becomes the lead line. Header labels are
// kept as `.sr-only` text so screen readers still hear "Division …" / "Overall …" though the
// layout conveys them visually. Used by every race row — tri/run (ResultRow), swim events
// (MeetCard), grouped races (RaceGroupCard) — so the right column reads identically. The
// 'current' variant is the pre-redesign labelled layout, kept for the /places-preview compare.
import { placement, divisionLabel, divisionRank } from '../lib/format';
interface Props {
	overallPlace?: number | null;
	overallFieldSize?: number | null;
	division?: string | null;
	divisionPlace?: number | null;
	/** 'stack' (default, shipped) = division-first, label-free. 'current' = the old labelled
	 *  Overall/Division fields, retained for the /places-preview comparison. */
	variant?: 'current' | 'stack';
}
const { overallPlace = null, overallFieldSize = null, division = null, divisionPlace = null, variant = 'stack' } = Astro.props;

const divLead = divisionRank(division, divisionPlace) || null;
const overallSub = overallPlace != null ? placement(overallPlace, overallFieldSize) : null;
---
{variant === 'stack' ? (
	<div class="places stack">
		{divLead ? (
			<Fragment>
				<div class="st-main"><span class="sr-only">Division </span>{divLead}</div>
				{overallSub && <div class="st-sub"><span class="sr-only">Overall </span>{overallSub}</div>}
			</Fragment>
		) : overallSub && (
			<div class="st-main"><span class="sr-only">Overall </span>{overallSub}</div>
		)}
	</div>
) : (
	<div class="places">
		{overallPlace != null && (
			<div class="pl"><span class="pl-k">Overall</span><span class="pl-v">{placement(overallPlace, overallFieldSize)}</span></div>
		)}
		{division && (
			<div class="pl"><span class="pl-k">Division</span><span class="pl-v">{divisionLabel(division, divisionPlace)}</span></div>
		)}
	</div>
)}

<style>
	.places { display: flex; flex-direction: column; justify-content: center; gap: var(--sp-3); min-width: 0; }
	.pl-k { display: block; font-family: var(--font-mono); font-size: var(--fs-label); letter-spacing: var(--ls-wider); text-transform: uppercase; color: var(--faint); }
	.pl-v { display: block; font-family: var(--font-mono); font-size: var(--fs-value); margin-top: 0.1rem; white-space: nowrap; }

	.places.stack { gap: 0.18rem; }
	.st-main { font-family: var(--font-mono); font-size: var(--fs-value); white-space: nowrap; }
	.st-sub { font-family: var(--font-mono); font-size: var(--fs-chip); letter-spacing: 0.04em; color: var(--faint); white-space: nowrap; }
</style>
