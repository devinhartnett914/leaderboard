---
// One non-swim race edition that 2+ family members ran, collapsed into a single card
// (mirrors the swim MeetCard): the race header once, then one sub-row per finisher
// with avatar + name, finish time, and place. Lives in the parent `.results` subgrid
// so finish times line up with every other card. Only used on the all-races feed.
import ResultMarks from './ResultMarks.astro';
import RaceTitle from './RaceTitle.astro';
import PersonChip from './PersonChip.astro';
import Avatar from './Avatar.astro';
import DateRail from './DateRail.astro';
import CardSubMeta from './CardSubMeta.astro';
import ResultPlaces from './ResultPlaces.astro';
import FinishTime from './FinishTime.astro';
import { categoryOf, catColor } from '../lib/categories';
import { SPORT_LABELS, type Sport } from '../lib/types';
import { formatTime, abbrevDivision, raceDistanceLabel } from '../lib/format';
import { award, podiumPlace, type RaceEntry, type PrContext } from '../lib/feed';

interface Props {
	entry: RaceEntry;
	prCtx: PrContext;
	placesVariant?: 'current' | 'stack';
}
const { entry, prCtx, placesVariant = 'stack' } = Astro.props;
const results = entry.results;
const lead = results[0];
const ed = lead.race_edition;
const sport = (ed?.race?.sport ?? 'other') as Sport;
const cat = categoryOf(lead);
const edge = catColor(cat.key);
const typeLabel = sport === 'triathlon' ? cat.label : SPORT_LABELS[sport];
const distLabel = (sport !== 'triathlon' || cat.key === 'triathlon') ? raceDistanceLabel(ed?.distance_or_format, ed?.race?.name) : null;
const places = [...new Set(results.map(podiumPlace).filter((p): p is number => p != null))].join(' ');
const anyPr = results.some((r) => prCtx.prBadge(r));
// every family member who ran this race → the avatars + "N Racers" badge below the name
const racers = results.map((r) => r.person).filter((p): p is NonNullable<typeof p> => p != null);
---
<article class="gcard feed-card" data-cat={cat.key} data-place={places} data-pr={anyPr ? '1' : '0'} style={`--edge:${edge}; grid-template-rows: repeat(${1 + results.length}, auto)`}>
	<DateRail date={ed?.date} year={ed?.year} />
	<div class="gc-head">
		<span class="gc-ava">
			<span class="gc-ava-stack">
				{racers.map((p) => (
					<span class="gc-ava-s"><Avatar src={p.avatar_url} name={p.full_name} size={40} /></span>
				))}
			</span>
		</span>
		<div class="gc-hbody">
			<RaceTitle catKey={cat.key} name={ed?.race?.name ?? 'Race'} href={ed?.race ? `/races/${ed.race.slug}` : null} />
			<CardSubMeta type={typeLabel} catKey={cat.key} distance={distLabel} location={ed?.race?.location} />
		</div>
	</div>
	{results.map((r, i) => {
		const aw = award(r);
		const pr = prCtx.prBadge(r);
		const dnf = r.status !== 'finished';
		const row = 2 + i;
		return (
			<Fragment>
				<div class="gc-who" style={`grid-row:${row}`}>
					<PersonChip person={r.person} avatar={20} plain href={ed?.race?.slug && r.person?.slug ? `/races/${ed.race.slug}?who=${encodeURIComponent(r.person.slug)}` : null} />
				</div>
				<div class="gc-time" style={`grid-row:${row}`}>
					<span class="gc-timewrap">
						<ResultMarks medalTier={aw ? aw.tier : null} medalSub={aw ? abbrevDivision(aw.sub) : null} pr={!!pr} compact />
						<FinishTime time={dnf ? '' : formatTime(r.finish_time_seconds)} status={r.status} pr={!!pr?.gold} />
					</span>
				</div>
				<div class="gc-place" style={`grid-row:${row}`}>
					<ResultPlaces overallPlace={r.overall_place} overallFieldSize={r.overall_field_size} division={r.division} divisionPlace={r.division_place} variant={placesVariant} />
				</div>
			</Fragment>
		);
	})}
</article>

<style>

	/* Option D: avatar stack on the left, name + meta to its right; same header height as before. */
	.gc-head { grid-column: 2 / -1; grid-row: 1; display: flex; flex-direction: row; align-items: center; gap: 0.7rem; padding: 0.8rem 1.1rem 1rem; border-bottom: 1px solid var(--border); }
	.gc-ava { flex-shrink: 0; display: inline-flex; }
	.gc-ava-stack { display: inline-flex; align-items: center; }
	.gc-ava-s + .gc-ava-s { margin-left: -0.55rem; }
	.gc-ava-s :global(.avatar) { box-shadow: 0 0 0 2px var(--surface); }
	.gc-hbody { display: flex; flex-direction: column; align-items: flex-start; gap: 0.4rem; min-width: 0; }

	/* one sub-row per finisher: name (PersonChip) | time | place, divided by hairlines.
	   Vertical padding is set so the medal/PR mark (which is taller than the time line and
	   sits vertically centered) clears the hairline dividers instead of butting them (DEV-23). */
	.gc-who { grid-column: 2; display: flex; align-items: center; padding: 0.65rem 1.1rem; min-width: 0; border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent); }
	.gc-time { grid-column: 3 / 5; position: relative; display: flex; align-items: center; padding: 0.65rem 1.1rem; border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent); }
	.gc-timewrap { position: relative; width: max-content; }
	.gc-place { grid-column: 5; display: flex; flex-direction: column; justify-content: center; padding: 0.65rem 1.2rem 0.65rem 1.1rem; border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent); }
	/* first finisher row sits directly under the header — no doubled divider */
	.gc-head + .gc-who, .gc-head + .gc-who + .gc-time, .gc-head + .gc-who + .gc-time + .gc-place { border-top: none; }
</style>
