---
// THROWAWAY (DEV-30) — one all-races feed card rendered in a chosen head VARIANT, so the
// four location treatments can be compared side by side on /dev30-preview.
// - A/B/C use their original Round-4 layouts (standard card head); only D uses the large-avatar-left.
// - ALL variants receive real person objects (with real avatar_url) from the preview page.
// Delete this file + /dev30-preview once a layout is picked, then implement the winner in
// the real ResultRow / MeetCard / RaceGroupCard.
import DateRail from './DateRail.astro';
import RaceTitle from './RaceTitle.astro';
import Avatar from './Avatar.astro';
import RacerBadge from './RacerBadge.astro';
import ResultMarks from './ResultMarks.astro';
import FinishTime from './FinishTime.astro';
import ResultPlaces from './ResultPlaces.astro';
import { catColor, catIcon } from '../lib/categories';

type Racer = { full_name: string; slug: string | null; avatar_url: string | null };
interface Props {
	variant: 'A' | 'B' | 'C' | 'D';
	catKey: string;
	name: string;
	type: string;
	distance?: string | null;
	location: string;
	racers: Racer[];
	date?: string | null;
	year?: number | null;
	finish: string;
	pr?: boolean;
	medalTier?: number | null;
	medalSub?: string | null;
	division?: string | null;
	divisionPlace?: number | null;
	overallPlace?: number | null;
	overallFieldSize?: number | null;
}
const {
	variant, catKey, name, type, distance = null, location, racers,
	date = null, year = null, finish, pr = false, medalTier = null, medalSub = null,
	division = null, divisionPlace = null, overallPlace = null, overallFieldSize = null,
} = Astro.props;
const edge = catColor(catKey);
const icon = catIcon(catKey);
---
<article class:list={['feed-card', 'pv-card', `v-${variant.toLowerCase()}`]} style={`--edge:${edge}`}>
	<DateRail date={date} year={year} />

	{/* ── OPTIONS A + B: Standard head (race name → sub-meta below, like ResultRow) ── */}
	{(variant === 'A' || variant === 'B') && (
		<div class="pv-head pv-head-std">
			<RaceTitle catKey={catKey} name={name} href="#" />
			<div class="pv-submeta">
				{variant === 'A' ? (
					/* A: location folded INTO the type strip, edge-colored */
					<span class="pv-meta-strip">
						<span class="pv-ic">{icon}</span>
						<span class="pv-type">{type}</span>
						{distance && <span class="pv-edge-seg">· {distance}</span>}
						<span class="pv-edge-seg">· {location}</span>
					</span>
				) : (
					/* B: clean type strip, location will appear in the top-right corner */
					<span class="pv-meta-strip">
						<span class="pv-ic">{icon}</span>
						<span class="pv-type">{type}</span>
						{distance && <span class="pv-edge-seg">· {distance}</span>}
					</span>
				)}
				{racers.length > 0 && (
					<Fragment>
						<span class="pv-pipe" aria-hidden="true">|</span>
						<RacerBadge racers={racers} />
					</Fragment>
				)}
			</div>
		</div>
	)}

	{/* ── OPTION C: Racer above title, location pipe-separated beside type in gray ── */}
	{variant === 'C' && (
		<div class="pv-head pv-head-std">
			{racers.length > 0 && (
				<div class="pv-racer-above">
					<RacerBadge racers={racers} />
				</div>
			)}
			<RaceTitle catKey={catKey} name={name} href="#" />
			<div class="pv-submeta">
				<span class="pv-meta-strip">
					<span class="pv-ic">{icon}</span>
					<span class="pv-type">{type}</span>
					{distance && <span class="pv-edge-seg">· {distance}</span>}
				</span>
				<span class="pv-pipe-gray" aria-hidden="true">|</span>
				<span class="pv-loc-gray">{location}</span>
			</div>
		</div>
	)}

	{/* ── OPTION D: Large avatar on far left, name+tags block to its right (left-aligned) ── */}
	{variant === 'D' && (
		<div class="pv-head pv-head-d">
			{/* Avatar — large, always on the far left */}
			<span class="pv-ava">
				{racers.length === 1 ? (
					<Avatar src={racers[0].avatar_url} name={racers[0].full_name} size={46} />
				) : (
					<span class="pv-ava-stack">
						{racers.map((r) => (
							<span class="pv-ava-s"><Avatar src={r.avatar_url} name={r.full_name} size={38} /></span>
						))}
					</span>
				)}
			</span>
			{/* Body — race name + TYPE | location */}
			<div class="pv-body">
				<RaceTitle catKey={catKey} name={name} href="#" />
				<span class="pv-meta-strip pv-meta-d">
					<span class="pv-ic">{icon}</span>
					<span class="pv-type">{type}</span>
					{distance && <span class="pv-edge-seg">· {distance}</span>}
					<span class="pv-pipe" aria-hidden="true">|</span>
					<span class="pv-loc-gray">{location}</span>
				</span>
			</div>
		</div>
	)}

	{/* ── finish + standing (identical across variants) ── */}
	<div class="pv-finish">
		<span class="pv-timewrap">
			<ResultMarks medalTier={medalTier} medalSub={medalSub} pr={pr} />
			<FinishTime time={finish} pr={pr} />
		</span>
	</div>
	<div class="pv-places">
		<ResultPlaces overallPlace={overallPlace} overallFieldSize={overallFieldSize} division={division} divisionPlace={divisionPlace} />
	</div>

	{/* variant B: location parked in the card's top-right corner */}
	{variant === 'B' && <span class="pv-loc-tr">{location}</span>}
</article>

<style>
	/* card lives in the parent .results subgrid; position:relative anchors variant B's corner label */
	.pv-card { position: relative; align-items: stretch; }

	/* STANDARD head (A, B, C) — flex column like .rc-head in ResultRow.
	   Race name leads; sub-meta sits 0.4rem below it. */
	.pv-head-std {
		grid-column: 2;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		gap: 0.4rem;
		padding: 0.85rem 1.1rem;
		min-width: 0;
	}

	/* D: large avatar on the far left, body (name + meta) to its right, all left-aligned */
	.pv-head-d {
		grid-column: 2;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: flex-start;
		gap: 0.75rem;
		padding: 0.85rem 1.1rem;
		min-width: 0;
	}

	/* sub-meta row (A, B, C) — like .submeta in CardSubMeta */
	.pv-submeta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		min-width: 0;
		flex-wrap: nowrap;
	}

	/* mono-uppercase type/location strip — like .cardmeta in CardMeta */
	.pv-meta-strip {
		flex-shrink: 0;
		display: inline-flex;
		align-items: baseline;
		gap: 0.35rem;
		font-family: var(--font-mono);
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		white-space: nowrap;
	}
	/* In D's body the strip is inline with a centered racer (not baseline) */
	.pv-meta-d { align-items: center; }

	.pv-ic { align-self: center; flex-shrink: 0; font-size: 0.95rem; line-height: 1; font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', emoji; }
	/* type + distance + (A) location: all edge-colored */
	.pv-type, .pv-edge-seg { color: var(--edge); }
	/* pipe between strip and RacerBadge (A, B) */
	.pv-pipe { flex-shrink: 0; color: var(--line-strong); font-family: var(--font-mono); font-size: 0.62rem; font-weight: 600; }

	/* C: gray pipe between type and location */
	.pv-pipe-gray { flex-shrink: 0; color: var(--line-strong); font-family: var(--font-mono); font-size: 0.62rem; font-weight: 600; }
	/* C + D: location in gray */
	.pv-loc-gray { flex-shrink: 0; color: var(--muted); font-family: var(--font-mono); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; }

	/* C: racer chip sits above the race title */
	.pv-racer-above { /* no extra styling needed — flex-column gap handles spacing */ }

	/* B: location in the card's top-right corner, small gray */
	.pv-loc-tr {
		position: absolute;
		top: 0.7rem;
		right: 1rem;
		font-family: var(--font-mono);
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--muted);
		white-space: nowrap;
		pointer-events: none;
	}

	/* D: avatar container */
	.pv-ava { flex-shrink: 0; display: inline-flex; align-items: center; }
	.pv-ava-stack { display: inline-flex; align-items: center; }
	.pv-ava-s + .pv-ava-s { margin-left: -0.6rem; }
	.pv-ava-s :global(.avatar) { box-shadow: 0 0 0 2px var(--surface); }

	/* D: name + meta column */
	.pv-body {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		gap: 0.35rem;
		min-width: 0;
	}

	.pv-finish { grid-column: 3; position: relative; display: flex; flex-direction: column; justify-content: center; padding: 0 1.1rem; }
	.pv-timewrap { position: relative; width: max-content; }
	.pv-places { grid-column: 5; display: flex; flex-direction: column; justify-content: center; padding: 0 1.2rem 0 1.1rem; }
</style>
