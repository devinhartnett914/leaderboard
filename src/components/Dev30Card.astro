---
// THROWAWAY (DEV-30) — one all-races feed card rendered in a chosen head VARIANT, so the
// four location/racer layouts tried in this ticket can be compared side by side on
// /dev30-preview. Only the card HEAD (column 2) changes between variants; the date rail and
// the right-hand finish + standing are identical (and reuse the real leaf components), so the
// comparison is faithful. Delete this file + /dev30-preview once a layout is picked, and
// implement the winner in the real ResultRow / MeetCard / RaceGroupCard.
import DateRail from './DateRail.astro';
import RaceTitle from './RaceTitle.astro';
import RacerBadge from './RacerBadge.astro';
import Avatar from './Avatar.astro';
import ResultMarks from './ResultMarks.astro';
import FinishTime from './FinishTime.astro';
import ResultPlaces from './ResultPlaces.astro';
import { catColor, catIcon } from '../lib/categories';

type Racer = { full_name: string; slug: string | null; avatar_url: string | null };
interface Props {
	variant: 'A' | 'B' | 'C' | 'D';
	catKey: string;
	name: string;
	type: string;
	distance?: string | null;
	location: string;
	racers: Racer[];
	date?: string | null;
	year?: number | null;
	finish: string;
	pr?: boolean;
	medalTier?: number | null;
	medalSub?: string | null;
	division?: string | null;
	divisionPlace?: number | null;
	overallPlace?: number | null;
	overallFieldSize?: number | null;
}
const {
	variant, catKey, name, type, distance = null, location, racers,
	date = null, year = null, finish, pr = false, medalTier = null, medalSub = null,
	division = null, divisionPlace = null, overallPlace = null, overallFieldSize = null,
} = Astro.props;
const edge = catColor(catKey);
const icon = catIcon(catKey);
---
<article class:list={['feed-card', 'pv-card', `v-${variant.toLowerCase()}`]} style={`--edge:${edge}`}>
	<DateRail date={date} year={year} />

	{/* ── HEAD (column 2) — the only part that changes between variants ── */}
	{variant === 'A' && (
		<div class="pv-head">
			<RaceTitle catKey={catKey} name={name} href="#" />
			<span class="pv-meta">
				<span class="pv-ic">{icon}</span>
				<span class="pv-type">{type}</span>
				{distance && <span class="pv-dist">· {distance}</span>}
				<span class="pv-loc-edge">· {location}</span>
				{racers.length > 0 && (
					<Fragment>
						<span class="pv-pipe" aria-hidden="true">|</span>
						<RacerBadge racers={racers} />
					</Fragment>
				)}
			</span>
		</div>
	)}

	{variant === 'B' && (
		<div class="pv-head">
			<RaceTitle catKey={catKey} name={name} href="#" />
			<span class="pv-meta">
				<span class="pv-ic">{icon}</span>
				<span class="pv-type">{type}</span>
				{distance && <span class="pv-dist">· {distance}</span>}
				{racers.length > 0 && (
					<Fragment>
						<span class="pv-pipe" aria-hidden="true">|</span>
						<RacerBadge racers={racers} />
					</Fragment>
				)}
			</span>
		</div>
	)}

	{variant === 'C' && (
		<div class="pv-head">
			{racers.length > 0 && <RacerBadge racers={racers} />}
			<RaceTitle catKey={catKey} name={name} href="#" />
			<span class="pv-meta">
				<span class="pv-ic">{icon}</span>
				<span class="pv-type">{type}</span>
				{distance && <span class="pv-dist">· {distance}</span>}
				<span class="pv-pipe" aria-hidden="true">|</span>
				<span class="pv-loc-gray">{location}</span>
			</span>
		</div>
	)}

	{variant === 'D' && (
		<div class="pv-head pv-head-d">
			<span class="pv-ava">
				{racers.length === 1 ? (
					<Avatar src={racers[0].avatar_url} name={racers[0].full_name} size={46} />
				) : (
					<span class="pv-ava-stack">
						{racers.map((r) => (
							<span class="pv-ava-s"><Avatar src={r.avatar_url} name={r.full_name} size={40} /></span>
						))}
					</span>
				)}
			</span>
			<div class="pv-body">
				<RaceTitle catKey={catKey} name={name} href="#" />
				<span class="pv-meta">
					<span class="pv-ic">{icon}</span>
					<span class="pv-type">{type}</span>
					{distance && <span class="pv-dist">· {distance}</span>}
					<span class="pv-pipe" aria-hidden="true">|</span>
					<span class="pv-loc-gray">{location}</span>
				</span>
			</div>
		</div>
	)}

	{/* ── finish + standing (identical across variants) ── */}
	<div class="pv-finish">
		<span class="pv-timewrap">
			<ResultMarks medalTier={medalTier} medalSub={medalSub} pr={pr} />
			<FinishTime time={finish} pr={pr} />
		</span>
	</div>
	<div class="pv-places">
		<ResultPlaces overallPlace={overallPlace} overallFieldSize={overallFieldSize} division={division} divisionPlace={divisionPlace} />
	</div>

	{/* variant B parks the location in the card's top-right corner */}
	{variant === 'B' && <span class="pv-loc-tr">{location}</span>}
</article>

<style>
	/* the card is a subgrid of the parent .results grid (date · head · finish · — · standing),
	   exactly like a real feed card. position:relative so variant B can park the location top-right. */
	.pv-card { position: relative; align-items: stretch; }

	.pv-head { grid-column: 2; display: flex; flex-direction: column; align-items: flex-start; justify-content: center; gap: 0.4rem; padding: 0.85rem 1.1rem; min-width: 0; }

	/* variant D: large avatar on the far left, name + tags to its right, vertically centered.
	   justify-content: flex-start keeps everything left-aligned in the column. */
	.pv-head-d { flex-direction: row; align-items: center; justify-content: flex-start; gap: 0.7rem; }
	.pv-ava { flex-shrink: 0; display: inline-flex; }
	.pv-ava-stack { display: inline-flex; align-items: center; }
	.pv-ava-s + .pv-ava-s { margin-left: -0.55rem; }
	.pv-ava-s :global(.avatar) { box-shadow: 0 0 0 2px var(--surface); }
	.pv-body { display: flex; flex-direction: column; align-items: flex-start; justify-content: center; gap: 0.4rem; min-width: 0; }

	/* the meta strip — mono-uppercase, same voice as the real CardMeta. type/distance take the
	   card edge color; the icon is a native color emoji (not tinted). */
	.pv-meta { display: inline-flex; align-items: center; gap: 0.4rem; min-width: 0; flex-wrap: nowrap; font-family: var(--font-mono); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; white-space: nowrap; }
	.pv-ic { align-self: center; flex-shrink: 0; font-size: 0.95rem; line-height: 1; font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', emoji; }
	.pv-type, .pv-dist { color: var(--edge); }
	.pv-pipe { flex-shrink: 0; color: var(--line-strong); font-size: 0.62rem; }
	/* location beside the type — gray chrome (variants C/D) */
	.pv-loc-gray { flex-shrink: 0; color: var(--muted); }
	/* location folded INTO the type strip, edge-colored (variant A) */
	.pv-loc-edge { flex-shrink: 0; color: var(--edge); }
	/* location parked in the card's top-right corner, small + gray (variant B) */
	.pv-loc-tr { position: absolute; top: 0.7rem; right: 1rem; font-family: var(--font-mono); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); white-space: nowrap; pointer-events: none; }

	.pv-finish { grid-column: 3; position: relative; display: flex; flex-direction: column; justify-content: center; padding: 0 1.1rem; }
	.pv-timewrap { position: relative; width: max-content; }
	.pv-places { grid-column: 5; display: flex; flex-direction: column; justify-content: center; padding: 0 1.2rem 0 1.1rem; }
</style>
