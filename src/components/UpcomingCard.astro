---
// Home-page teaser TILE for one upcoming race — the forward-looking sibling of
// RecentCard. The category tag + who's racing (RacerBadge: one chip, or avatars + "N
// Racers") share the meta line BELOW the race name (via CardSubMeta, the card standard);
// the location sits right under the title. The date lives on the DateRail, so it isn't repeated.
import DateRail from './DateRail.astro';
import CardSubMeta from './CardSubMeta.astro';
import RaceTitle from './RaceTitle.astro';
import { categoryOf, catColor } from '../lib/categories';
import { SPORT_LABELS, type Sport } from '../lib/types';
import { raceDistanceLabel, formatLocation } from '../lib/format';
import type { UpcomingRace } from '../lib/queries';

interface Props { race: UpcomingRace }
const { race: ed } = Astro.props;
const sport = (ed.race?.sport ?? 'other') as Sport;
const cat = categoryOf({ race_edition: { distance_or_format: ed.distance_or_format, race: { sport, name: ed.race?.name } } });
const edge = catColor(cat.key);
const typeLabel = sport === 'triathlon' ? cat.label : SPORT_LABELS[sport];
const distance = (sport !== 'triathlon' || cat.key === 'triathlon') ? raceDistanceLabel(ed.distance_or_format, ed.race?.name) : null;
const racers = ed.racers ?? [];
---
<article class="up-tile" data-cat={cat.key} style={`--edge:${edge}`}>
	<DateRail date={ed.date} year={ed.year} />
	<div class="ut-body">
		<RaceTitle catKey={cat.key} name={ed.race?.name ?? 'Race'} />
		<CardSubMeta type={typeLabel} catKey={cat.key} distance={distance} racers={racers} />
		{ed.race?.location && <span class="ut-loc">{formatLocation(ed.race.location)}</span>}
	</div>
</article>

<style>
	/* tile shell mirrors RecentCard's `.recent` (DateRail + body, category edge accent,
	   shared gradient/radius) so the Upcoming tiles sit flush beside the Recent ones. */
	.up-tile {
		display: grid; grid-template-columns: 86px 1fr; align-items: stretch; color: var(--text);
		background: linear-gradient(180deg, var(--surface-2), var(--surface) 90px);
		border: 1px solid var(--border); border-left: 3px solid var(--edge);
		border-radius: 14px; box-shadow: var(--shadow); overflow: hidden;
	}
	/* stretch (not flex-start) so the race name is width-constrained to the tile and
	   ellipsizes when long (DEV-19); location + meta are left-aligned text either way. */
	.ut-body { display: flex; flex-direction: column; align-items: stretch; gap: 0.4rem; padding: 0.85rem 1rem; min-width: 0; }
	/* location in the division-rank treatment (mono, --fs-value) — reads as race data,
	   matching the standings value on the feed rows rather than body text (DEV-21). */
	.ut-loc { font-family: var(--font-mono); font-size: var(--fs-value); color: var(--muted); }
</style>
