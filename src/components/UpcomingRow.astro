---
// One UPCOMING race as a feed row, living in the shared `.results` subgrid so it lines
// up with every other row on /races and /people. The category tag + who's racing
// (RacerBadge: one chip, or avatars + "N Racers") share the meta line ABOVE the race name
// (via CardSubMeta); the location sits on the right where a finish time would be. No detail
// link (upcoming editions don't get a page until results land). `.is-upcoming` lets the
// year-line toggle collapse/expand these rows.
import DateRail from './DateRail.astro';
import CardSubMeta from './CardSubMeta.astro';
import RaceTitle from './RaceTitle.astro';
import { categoryOf, catColor } from '../lib/categories';
import { SPORT_LABELS, type Sport } from '../lib/types';
import type { UpcomingRace } from '../lib/queries';

interface Props {
	race: UpcomingRace;
	anchorId?: string | null; // so a deep-link (Home → /races#upcoming) can scroll to it
}
const { race: ed, anchorId = null } = Astro.props;
const sport = (ed.race?.sport ?? 'other') as Sport;
// same category resolution every card uses (triathlon splits into sprint/olympic/kids)
const cat = categoryOf({ race_edition: { distance_or_format: ed.distance_or_format, race: { sport, name: ed.race?.name } } });
const edge = catColor(cat.key);
const typeLabel = sport === 'triathlon' ? cat.label : SPORT_LABELS[sport];
const showDist = ed.distance_or_format && (sport !== 'triathlon' || cat.key === 'triathlon');
const racers = ed.racers ?? [];
---
<article class="ucard feed-card is-upcoming" id={anchorId ?? undefined} data-cat={cat.key} data-year={String(ed.year ?? '')} data-pr="0" style={`--edge:${edge}`}>
	<DateRail date={ed.date} year={ed.year} />
	<div class="uc-body">
		<CardSubMeta type={typeLabel} catKey={cat.key} distance={showDist ? ed.distance_or_format : null} racers={racers} />
		<RaceTitle catKey={cat.key} name={ed.race?.name ?? 'Race'} />
	</div>
	<div class="uc-meta">
		{ed.race?.location && <span class="uc-loc">{ed.race.location}</span>}
	</div>
</article>

<style>
	/* single-row card; body in the name column (racer · name · category, stacked), the
	   location right-aligned where a finish time would sit, so the row reads like the feed. */
	.ucard { grid-template-rows: auto; }
	.uc-body { grid-column: 2; display: flex; flex-direction: column; align-items: flex-start; justify-content: center; gap: 0.25rem; padding: 0.85rem 1.1rem; min-width: 0; }
	.uc-meta { grid-column: 3 / -1; display: flex; align-items: center; justify-content: flex-end; padding: 0.85rem 1.2rem; }
	/* location in the standard body font (not mono caps) */
	.uc-loc { font-family: var(--font-body); font-size: 0.82rem; color: var(--muted); text-align: right; }
</style>
