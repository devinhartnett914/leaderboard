---
// One tri/run result row, shared by the person page and the all-races feed. Lives in
// the parent `.results` subgrid. Anatomy: the type · category tag + racer sit in a band
// ABOVE the race name (the card standard), then the race name + finish time + legs +
// standing share ONE row below (so the finish time lines up with the race NAME).
import ResultMarks from './ResultMarks.astro';
import RaceTitle from './RaceTitle.astro';
import DateRail from './DateRail.astro';
import CardSubMeta from './CardSubMeta.astro';
import ResultPlaces from './ResultPlaces.astro';
import FinishTime from './FinishTime.astro';
import { categoryOf, catColor } from '../lib/categories';
import { SPORT_LABELS, type Sport } from '../lib/types';
import { formatTime, legPace, legIcon, legColor, abbrevDivision } from '../lib/format';
import { podiumPlace, type FeedRow, type PrBadge } from '../lib/feed';

interface Props {
	r: FeedRow;
	pr: PrBadge | null;
	aw: { tier: number; sub: string } | null;
	showPerson?: boolean;
	placesVariant?: 'current' | 'stack';
}
const { r, pr, aw, showPerson = false, placesVariant = 'stack' } = Astro.props;
const ed = r.race_edition;
const sport = (ed?.race?.sport ?? 'other') as Sport;
const cat = categoryOf(r);
const legs = (r.split ?? []).filter((s) => !/^t\d/i.test(s.label));
const edge = catColor(cat.key);
const typeLabel = sport === 'triathlon' ? cat.label : SPORT_LABELS[sport];
const showDist = ed?.distance_or_format && (sport !== 'triathlon' || cat.key === 'triathlon');
// On the combined feed the result carries its person → show them on the meta band above the
// name; on a person's own page there's no person to show.
const racers = showPerson && r.person ? [r.person] : [];
---
<article class:list={['rcard', 'feed-card', { 'has-marks': aw || pr }]} data-cat={cat.key} data-place={String(podiumPlace(r) ?? '')} data-pr={pr ? '1' : '0'} data-person={r.person?.id ?? ''} data-year={String(ed?.year ?? '')} style={`--edge:${edge}`}>
	<DateRail date={ed?.date} year={ed?.year} />
	<div class="rc-meta">
		<CardSubMeta type={typeLabel} catKey={cat.key} distance={showDist ? ed?.distance_or_format : null} event={r.event} racers={racers} />
	</div>
	<div class="rc-name">
		<RaceTitle catKey={cat.key} name={ed?.race?.name ?? 'Unknown race'} href={ed?.race ? `/races/${ed.race.slug}` : null} />
	</div>
	<div class="rc-finish">
		{placesVariant === 'stack' ? <span class="sr-only">Finish </span> : <span class="rc-k">Finish</span>}
		<span class="rc-timewrap">
			<ResultMarks medalTier={aw ? aw.tier : null} medalSub={aw ? abbrevDivision(aw.sub) : null} pr={!!pr} />
			<FinishTime time={r.status === 'finished' ? formatTime(r.finish_time_seconds) : ''} status={r.status} pr={!!pr?.gold} />
		</span>
	</div>
	<div class="rc-legs">
		{legs.map((s) => (
			<div class="rc-leg">
				<span class="leg-ic" style={`color:${legColor(s.label)}`}>{legIcon(s.label)}</span>
				<span class="leg-t">{formatTime(s.segment_time_seconds)}</span>
				<span class="leg-p">{legPace(s.distance_m, s.segment_time_seconds, s.distance_unit) ?? ''}</span>
			</div>
		))}
	</div>
	<div class="rc-places">
		<ResultPlaces overallPlace={r.overall_place} overallFieldSize={r.overall_field_size} division={r.division} divisionPlace={r.division_place} variant={placesVariant} />
	</div>
</article>

<style>
	/* The type · category tag + racer is a band spanning the top (row 1); the race name +
	   finish time + legs + standing then sit together on ONE row below (row 2), so the
	   finish lines up with the NAME and the split icons (which float above each time) have
	   the band above for headroom. */
	.rcard { grid-template-rows: auto auto; }

	.rc-meta { grid-column: 2 / -1; grid-row: 1; padding: 0.8rem 1.1rem 0; min-width: 0; }

	.rc-name { grid-column: 2; grid-row: 2; display: flex; align-items: flex-start; padding: 0 1.1rem 0.85rem; min-width: 0; }
	.rcard.has-marks .rc-name { padding-right: 76px; }

	.rc-finish { grid-column: 3; grid-row: 2; position: relative; display: flex; flex-direction: column; justify-content: flex-start; gap: 0.2rem; padding: 0 1.1rem 0.85rem; }
	.rc-k { display: block; font-family: var(--font-mono); font-size: var(--fs-label); letter-spacing: var(--ls-wider); text-transform: uppercase; color: var(--faint); }
	.rc-timewrap { position: relative; width: max-content; }

	.rc-legs { grid-column: 4; grid-row: 2; display: flex; gap: 0.95rem; align-items: flex-start; padding: 0 1.1rem 0.85rem; }
	/* the leg TIME is the anchor: it sits on the same top line as the finish time and
	   the standing (all three cells are top-aligned). The discipline icon floats just
	   ABOVE the time (into the meta band) and the pace sits below — so a row of splits
	   reads time-first, in line with place/division instead of dropped a row. */
	.rc-leg { position: relative; display: flex; flex-direction: column; align-items: center; min-width: 54px; }
	.leg-ic { position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); margin-bottom: 0.12rem; font-size: 1.05rem; line-height: 1; }
	.leg-t { font-family: var(--font-mono); font-weight: 600; font-size: 0.86rem; }
	.leg-p { font-family: var(--font-mono); font-size: 0.58rem; color: var(--faint); }

	.rc-places { grid-column: 5; grid-row: 2; display: flex; flex-direction: column; justify-content: flex-start; padding: 0 1.2rem 0.85rem 1.1rem; }
</style>
