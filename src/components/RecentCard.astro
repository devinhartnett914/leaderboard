---
// Home-only teaser for one recent entry. Follows the all-races feed-card anatomy
// (DateRail on the left, race meta + title) but as a STANDALONE card. The finish
// block is: a label, then the figure with its marks, with the DIVISION shown beside
// it. Division is rendered ONE way (divisionParts/swimDivision, heat kept): under the
// medal when the result placed (PodiumMedal's caption), else in a standalone Division
// field. Types:
//   • single result (tri/run, or one race several family ran) → finish time · division.
//   • multi-event (a swim meet, later a ski race) → the standout result (by division
//     place) with its event name and division.
import RaceTitle from './RaceTitle.astro';
import ResultMarks from './ResultMarks.astro';
import CardTopRow from './CardTopRow.astro';
import DateRail from './DateRail.astro';
import Division from './Division.astro';
import EventChip from './EventChip.astro';
import { categoryOf, catColor } from '../lib/categories';
import { SPORT_LABELS, type Sport } from '../lib/types';
import { formatTime, formatSwimTime, swimDivision } from '../lib/format';
import { award, podiumPlace, bestEvent, swimCs, type Entry, type PrContext } from '../lib/feed';

interface Props {
	entry: Entry;
	prCtx: PrContext;
	// Event-chip placement. Production uses the default 'c' (stacked chip, right-aligned
	// like the division). The other values back the /recent-preview design comparison —
	// kept so we can revisit the iteration. See that page for the alternatives.
	variant?: 'current' | 'a' | 'b' | 'c' | 'd';
}
const { entry, prCtx, variant = 'c' } = Astro.props;

// Resolve a common shape regardless of entry type, then render one finish block.
let person = null as { full_name: string; slug: string | null; avatar_url: string | null } | null;
let extraPeople = 0;
let ed;
let catKey = 'other';
let edge = 'var(--border)';
let typeLabel = '';
let distance: string | null = null;
let figure = '';
let figureLabel = '';
let isGold = false;
let medalTier: number | null = null;
let pr = false;
let division: string | null = null;
let divisionPlace: number | null = null;
let overallPlace: number | null = null;
let eventStr: string | null = null; // which event the best result was (swim meets)

if (entry.type === 'meet') {
	const events = entry.events;
	person = events[0].person ?? null;
	ed = events[0].race_edition;
	catKey = 'swim_meet';
	edge = 'var(--swim)';
	typeLabel = 'Swim Meet';
	figureLabel = 'Best result';
	const best = bestEvent(events); // standout by division place, not merely fastest
	if (best) {
		medalTier = podiumPlace(best);
		pr = prCtx.isSwimPr(best);
		isGold = pr;
		figure = formatSwimTime(swimCs(best));
		division = best.division;
		divisionPlace = best.division_place;
		overallPlace = best.overall_place;
		eventStr = best.event;
	} else {
		figure = '—';
	}
} else if (entry.type === 'race') {
	const results = entry.results;
	const lead = results[0];
	person = lead.person ?? null;
	extraPeople = results.length - 1;
	ed = lead.race_edition;
	const cat = categoryOf(lead);
	const sport = (ed?.race?.sport ?? 'other') as Sport;
	catKey = cat.key;
	edge = catColor(cat.key);
	typeLabel = sport === 'triathlon' ? cat.label : SPORT_LABELS[sport];
	distance = ed?.distance_or_format && (sport !== 'triathlon' || cat.key === 'triathlon') ? ed?.distance_or_format : null;
	const aw = award(lead);
	const b = prCtx.prBadge(lead);
	medalTier = aw ? aw.tier : null;
	pr = !!b;
	isGold = !!b?.gold;
	figure = lead.status === 'finished' ? formatTime(lead.finish_time_seconds) : lead.status.toUpperCase();
	figureLabel = 'Fastest';
	division = lead.division;
	divisionPlace = lead.division_place;
	overallPlace = lead.overall_place;
} else {
	const r = entry.r;
	person = r.person ?? null;
	ed = r.race_edition;
	const cat = categoryOf(r);
	const sport = (ed?.race?.sport ?? 'other') as Sport;
	catKey = cat.key;
	edge = catColor(cat.key);
	typeLabel = sport === 'triathlon' ? cat.label : SPORT_LABELS[sport];
	distance = ed?.distance_or_format && (sport !== 'triathlon' || cat.key === 'triathlon') ? ed?.distance_or_format : null;
	const aw = award(r);
	const b = prCtx.prBadge(r);
	medalTier = aw ? aw.tier : null;
	pr = !!b;
	isGold = !!b?.gold;
	figure = r.status === 'finished' ? formatTime(r.finish_time_seconds) : r.status.toUpperCase();
	// No caption for a plain finish — the time speaks for itself (matches the label-free
	// feed cards). "Fastest"/"Best result" stay, since they flag a standout among several.
	figureLabel = '';
	division = r.division;
	divisionPlace = r.division_place;
	overallPlace = r.overall_place;
}

const raceName = ed?.race?.name ?? (entry.type === 'meet' ? 'Swim meet' : 'Race');
const hasMarks = !!(medalTier || pr);
// When the result placed, the medal carries its division (its caption); otherwise the
// standalone Division field shows the group + rank.
const medalSub = medalTier ? swimDivision(division) : null;
---
<article class:list={['recent', { 'has-marks': hasMarks }]} data-cat={catKey} style={`--edge:${edge}`}>
	<DateRail date={ed?.date} year={ed?.year} />
	<div class="rc-body">
		<CardTopRow person={person} type={typeLabel} distance={distance} />
		<RaceTitle catKey={catKey} name={raceName} href={ed?.race ? `/races/${ed.race.slug}` : null} />
		{extraPeople > 0 && <span class="rc-more">+{extraPeople} more family</span>}
		<div class="rc-finish" data-ev={variant}>
			{(figureLabel || (eventStr && (variant === 'current' || variant === 'b'))) && (
				<div class="rc-head">
					{figureLabel && <span class="rc-k">{figureLabel}</span>}
					{eventStr && (variant === 'current' || variant === 'b') && (
						<span class="rc-headev">
							{variant === 'b' && <span class="rc-sep">·</span>}
							<EventChip event={eventStr} />
						</span>
					)}
				</div>
			)}
			<div class="rc-row">
				<span class="rc-finrow">
					{eventStr && variant === 'a' && <EventChip event={eventStr} />}
					{eventStr && variant === 'd' && <EventChip event={eventStr} stack />}
					<ResultMarks medalTier={medalTier} medalSub={medalSub} pr={pr} compact inline />
					<span class:list={['rc-fig', { 'is-pr': isGold }]}>{figure}</span>
				</span>
				{!medalTier && <Division division={division} divisionPlace={divisionPlace} overallPlace={overallPlace} align="end" />}
				{/* C (production default): the standout event as a stacked chip, right-aligned like the division */}
				{eventStr && variant === 'c' && <EventChip event={eventStr} stack />}
			</div>
		</div>
	</div>
</article>

<style>
	/* A teaser TILE (sits in a cols-3 grid), built from the same pieces as a feed
	   row but stacked: DateRail on the left, body on the right. Shares the
	   .feed-card shell look (gradient, edge accent, radius, overflow). */
	.recent {
		display: grid; grid-template-columns: 86px 1fr; align-items: stretch; color: var(--text);
		background: linear-gradient(180deg, var(--surface-2), var(--surface) 90px);
		border: 1px solid var(--border); border-left: 3px solid var(--edge);
		border-radius: 14px; box-shadow: var(--shadow); overflow: hidden;
	}

	.rc-body { display: flex; flex-direction: column; gap: 0.4rem; padding: 0.85rem 1rem; min-width: 0; }
	.rc-more { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint); }

	/* finish block, pinned to the card bottom (margin-top:auto) so the figure lines up
	   across every card. Label, then the figure (with marks) on the left and — when the
	   result didn't medal — the Division field on the right. Event name sits beneath. */
	.rc-finish { display: flex; flex-direction: column; gap: 0.2rem; margin-top: auto; padding-top: 0.5rem; }
	/* label row: the figure caption on the left, the swim event chip on the right —
	   keeps the event name beside the header rather than stacked under the time. */
	.rc-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.6rem; min-width: 0; }
	.rc-k { font-family: var(--font-mono); font-size: var(--fs-label); letter-spacing: var(--ls-wider); text-transform: uppercase; color: var(--faint); }
	.rc-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 0.75rem; }
	.rc-finrow { display: inline-flex; align-items: flex-end; gap: 0.5rem; }
	.rc-fig { font-family: var(--font-display); font-weight: 400; font-size: var(--fs-time-lg); line-height: 0.9; letter-spacing: var(--ls-tight); white-space: nowrap; }
	.rc-fig.is-pr { color: var(--gold); }

	/* Event-chip placement variants (production default = 'c'). The others back the
	   /recent-preview comparison — kept so the design iteration is revisitable. */
	.rc-headev { display: inline-flex; align-items: baseline; gap: 0.4rem; min-width: 0; }
	.rc-sep { font-family: var(--font-mono); color: var(--faint); }
	.rc-finish[data-ev='b'] .rc-head { justify-content: flex-start; gap: 0.4rem; }
	.rc-finish[data-ev='a'] .rc-finrow { align-items: center; }
	/* c: stacked chip on the right of the time row — centered to sit level with the time + medal stack */
	.rc-finish[data-ev='c'] .rc-row { align-items: center; }
	.rc-finish[data-ev='d'] .rc-finrow { align-items: center; }
</style>
