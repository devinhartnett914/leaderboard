---
// A podium marker styled to match the "Podiums" filter chip: just the medal glyph
// (no circle/fill) with a small gray caption beneath it. The glyph itself conveys
// the rank (🥇🥈🥉), so the caption carries the division/group (e.g. "F40-44", "9-10").
// Sits to the LEFT of the time, next to the PR badge.
interface Props {
	tier: number; // 1 | 2 | 3
	sub?: string | null; // caption beneath the medal: division / age group
}
const { tier, sub = null } = Astro.props;
const MEDAL = ['🥇', '🥈', '🥉'];
const t = Math.min(Math.max(tier, 1), 3);
---
<span class="podmedal">
	<span class="pm-glyph">{MEDAL[t - 1]}</span>
	{sub && <span class="pm-lab">{sub}</span>}
</span>

<style>
	.podmedal { display: inline-flex; flex-direction: column; align-items: center; gap: 0.12rem; line-height: 1; }
	.pm-glyph { font-size: 1.2rem; line-height: 1; }
	.pm-lab { font-family: var(--font-mono); font-size: 0.5rem; letter-spacing: 0.02em; text-transform: uppercase; color: var(--muted); white-space: nowrap; }
</style>
