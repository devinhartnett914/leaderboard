---
// Podium marker: medal glyph (🥇🥈🥉) + a small caption carrying the division/age
// group. Glyph + caption sizing is kept identical to PrBadge (.mk-glyph / .mk-cap) so
// the two read as one family of marks when they sit side by side left of a time.
interface Props {
	tier: number; // 1 | 2 | 3
	sub?: string | null; // caption beneath the medal: division / age group
}
const { tier, sub = null } = Astro.props;
const MEDAL = ['🥇', '🥈', '🥉'];
const t = Math.min(Math.max(tier, 1), 3);
---
<span class="podmedal">
	<span class="mk-glyph">{MEDAL[t - 1]}</span>
	{sub && <span class="mk-cap">{sub}</span>}
</span>

<style>
	.podmedal { display: inline-flex; flex-direction: column; align-items: center; gap: 0.1rem; line-height: 1; }
	.mk-glyph { font-size: 1.1rem; line-height: 1; }
	.mk-cap { font-family: var(--font-mono); font-size: 0.5rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); white-space: nowrap; }
</style>
