---
// The meta line that sits DIRECTLY BELOW the race name on every card: the category/type
// tag (with its icon, via CardMeta) and — beside it — who's racing. The racer is a single
// PersonChip, or for an upcoming meet several avatars + a count; RacerBadge handles 1 vs
// many vs none. Category first, racer after, separated by a faint pipe. One component so
// the "type · racer" pairing and its tight spacing under the title are defined ONCE and
// stay consistent site-wide (DEV-19 / DEV-20).
import CardMeta from './CardMeta.astro';
import RacerBadge from './RacerBadge.astro';

type Racer = { full_name: string; slug: string | null; avatar_url: string | null };
interface Props {
	type: string;
	catKey?: string | null;
	distance?: string | null;
	event?: string | null;
	location?: string | null;
	racers?: Racer[];
}
const { type, catKey = null, distance = null, event = null, location = null, racers = [] } = Astro.props;
---
<div class="submeta">
	<CardMeta type={type} catKey={catKey} distance={distance} event={event} location={location} />
	{racers.length > 0 && (
		<Fragment>
			<span class="sm-pipe" aria-hidden="true">|</span>
			<RacerBadge racers={racers} />
		</Fragment>
	)}
</div>

<style>
	/* category tag + racer on ONE line, tight under the title — a small gap, no big space.
	   nowrap so the type stays next to the racer (the race name ellipsizes instead, per DEV-19). */
	.submeta { display: flex; align-items: center; gap: 0.5rem; min-width: 0; flex-wrap: nowrap; }
	.sm-pipe { flex-shrink: 0; color: var(--line-strong); font-family: var(--font-mono); font-size: 0.62rem; }
</style>
