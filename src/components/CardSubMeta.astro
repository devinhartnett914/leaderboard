---
// The meta line that sits DIRECTLY BELOW the race name on every card: the category/type
// tag (with its icon, via CardMeta) and — beside it — who's racing OR the race location.
// When `location` is passed (Option D feed cards), it shows as "| LOCATION" in gray and
// the racer badge is suppressed (the avatar moves to the card's left column instead).
// When only `racers` is passed, the racer badge shows as before.
import CardMeta from './CardMeta.astro';
import RacerBadge from './RacerBadge.astro';

type Racer = { full_name: string; slug: string | null; avatar_url: string | null };
interface Props {
	type: string;
	catKey?: string | null;
	distance?: string | null;
	event?: string | null;
	racers?: Racer[];
	location?: string | null;
}
const { type, catKey = null, distance = null, event = null, racers = [], location = null } = Astro.props;
---
<div class="submeta">
	<CardMeta type={type} catKey={catKey} distance={distance} event={event} />
	{location ? (
		<Fragment>
			<span class="sm-pipe" aria-hidden="true">|</span>
			<span class="sm-loc">{location}</span>
		</Fragment>
	) : racers.length > 0 ? (
		<Fragment>
			<span class="sm-pipe" aria-hidden="true">|</span>
			<RacerBadge racers={racers} />
		</Fragment>
	) : null}
</div>

<style>
	/* category tag + racer/location on ONE line, tight under the title — a small gap, no big space.
	   nowrap so the type stays next to the racer (the race name ellipsizes instead, per DEV-19). */
	.submeta { display: flex; align-items: center; gap: 0.5rem; min-width: 0; flex-wrap: nowrap; }
	.sm-pipe { flex-shrink: 0; color: var(--line-strong); font-family: var(--font-mono); font-size: 0.62rem; }
	.sm-loc { flex-shrink: 0; font-family: var(--font-mono); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); white-space: nowrap; }
</style>
