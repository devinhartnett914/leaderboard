---
// The shared "⭐ PR + time / caption" group used in track headers (race page,
// swim event page). Defines the star ↔ time relationship in ONE place so the gap
// matches the feed rows (ResultMarks padding-right: 0.55rem), with PR's caption
// row sharing a baseline with the time's caption (year / context).
import PrBadge from './PrBadge.astro';
interface Props {
	time: string; // formatted best time
	caption?: string | null; // year or other context shown under the time
	sizeRem?: number; // time font size in rem (defaults to 1.3rem)
}
const { time, caption = null, sizeRem = 1.3 } = Astro.props;
---
<span class="prtime" style={`--sz:${sizeRem}rem`}>
	<PrBadge />
	<span class="pt-stack">
		<b class="pt-time">{time}</b>
		{caption && <span class="pt-cap">{caption}</span>}
	</span>
</span>

<style>
	/* star ↔ time, bottom-aligned: the "PR" cap and the year/caption share one
	   baseline (align-items: flex-end), gap 0.5rem. The whole group reads as a
	   tidy stack — star above time, PR-cap beside the year. */
	.prtime { display: inline-flex; align-items: flex-end; gap: 0.5rem; }
	.pt-stack { display: inline-flex; flex-direction: column; align-items: center; gap: 0.1rem; line-height: 1; }
	.pt-time { font-family: var(--font-display); font-weight: 400; font-size: var(--sz); letter-spacing: 0.02em; line-height: 1; color: var(--gold); }
	.pt-cap { font-family: var(--font-mono); font-size: 0.5rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); line-height: 1; }
</style>
