---
import Layout from '../layouts/Layout.astro';
import RecentCard from '../components/RecentCard.astro';
import UpcomingCard from '../components/UpcomingCard.astro';
import Avatar from '../components/Avatar.astro';
import { getFamilyMembers, getAllFamilyResults, getUpcomingRaces } from '../lib/queries';
import { buildEntries, buildPrContext } from '../lib/feed';
import { currentAge } from '../lib/format';

const [family, allResults, upcoming] = await Promise.all([
	getFamilyMembers(),
	getAllFamilyResults(),
	getUpcomingRaces(),
]);
const prCtx = buildPrContext(allResults);
// the same grouping as /races — so a swim event lands inside its meet card
// and a multi-family-member race collapses into one shared row in both places.
const recentEntries = buildEntries(allResults, { groupRaces: true }).slice(0, 3);
// the soonest 3 upcoming races (getUpcomingRaces is ascending — nearest first)
const upcomingSoon = upcoming.slice(0, 3);

// Show the family oldest → youngest (earliest birth date first).
const birthKey = (p: (typeof family)[number]) =>
	p.birth_date ?? (p.birth_year ? `${p.birth_year}-00-00` : '9999-99-99');
const familyByAge = [...family].sort((a, b) => birthKey(a).localeCompare(birthKey(b)));
---

<Layout title="Leaderboard">
	<section class="hero">
		<div class="eyebrow">Family Race Tracker</div>
		<h1>Every race.<br />Every year.<br /><span>One place.</span></h1>
		<p class="muted">
			Whatever your multisport athletes race — with year-over-year times,
			split-by-split pace, and every personal record tracked as you chase it.
		</p>
	</section>

	<section class="block">
		<div class="section-head"><h2>Family</h2></div>
		{
			family.length === 0 ? (
				<div class="empty">No family members yet.</div>
			) : (
				<div class="grid cols-3">
					{familyByAge.map((p) => {
						const age = currentAge(p.birth_date, p.birth_year);
						return (
							<a class="card person-card" href={`/people/${p.slug}`}>
								<Avatar src={p.avatar_url} name={p.full_name} size={48} />
								<div>
									<div class="name">{p.full_name}</div>
									<div class="sub">{[p.gender, age != null && `Age ${age}`].filter(Boolean).join(' · ') || 'View results'}</div>
								</div>
							</a>
						);
					})}
				</div>
			)
		}
	</section>

	{upcomingSoon.length > 0 && (
		<section class="block">
			<div class="section-head">
				<h2>Upcoming</h2>
				<a href="/races#upcoming" class="all-link">All →</a>
			</div>
			<div class="grid cols-3">
				{upcomingSoon.map((u) => <UpcomingCard race={u} />)}
			</div>
		</section>
	)}

	<section class="block">
		<div class="section-head">
			<h2>Recent races</h2>
			<a href="/races" class="all-link">All →</a>
		</div>
		{
			recentEntries.length === 0 ? (
				<div class="empty">No races recorded yet.</div>
			) : (
				<div class="grid cols-3">
					{recentEntries.map((it) => <RecentCard entry={it} prCtx={prCtx} />)}
				</div>
			)
		}
	</section>
</Layout>

<style>
	.hero { margin: 1rem 0 3rem; }
	.eyebrow { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
	.hero h1 { margin: 0 0 1rem; font-family: var(--font-display); font-weight: 400; font-size: clamp(3rem, 9vw, 5.5rem); line-height: 0.9; letter-spacing: 0.02em; }
	.hero h1 span { color: var(--accent); }
	.hero p { margin: 0; max-width: 54ch; font-size: 1.05rem; }

	.block { margin-bottom: 2.75rem; }
	.section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1rem; }
	.section-head h2 { margin: 0; font-family: var(--font-display); font-weight: 400; font-size: 1.7rem; letter-spacing: 0.04em; }
	.all-link { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; }

	.person-card { display: flex; align-items: center; gap: 0.9rem; color: var(--text); transition: border-color 0.15s, transform 0.15s; }
	.person-card:hover { text-decoration: none; border-color: var(--accent); transform: translateY(-2px); }
	.name { font-family: var(--font-display); font-weight: 400; font-size: 1.3rem; letter-spacing: 0.02em; }
	.sub { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint); margin-top: 0.15rem; }
	/* Family-card gender·age reads blue, matching the person-page subtitle (the one
	   "person meta" treatment). The race-card sub (date · location) stays muted. */
	.person-card .sub { color: var(--accent); }

	/* Recent races are teaser TILES (RecentCard) in the shared cols-3 grid — each a
	   self-contained card that summarizes one entry, built from the same DateRail /
	   RaceTitle / CardSubMeta / ResultMarks pieces the all-races feed rows use. */
</style>
