---
import Layout from '../../layouts/Layout.astro';
import ResultRow from '../../components/ResultRow.astro';
import MeetCard from '../../components/MeetCard.astro';
import RaceGroupCard from '../../components/RaceGroupCard.astro';
import Avatar from '../../components/Avatar.astro';
import { getAllFamilyResults } from '../../lib/queries';
import type { Person } from '../../lib/types';
import { buildEntries, buildPrContext, award, type Entry } from '../../lib/feed';

const results = await getAllFamilyResults();
const prCtx = buildPrContext(results);
// group a single edition run by 2+ family members into one shared card
const entries = buildEntries(results, { groupRaces: true });

// the family, oldest → youngest, for the avatar links (each navigates to a person page)
const personCounts = new Map<string, { person: Person; count: number }>();
for (const r of results) {
	if (!r.person) continue;
	const e = personCounts.get(r.person.id) ?? { person: r.person, count: 0 };
	e.count++;
	personCounts.set(r.person.id, e);
}
const people = [...personCounts.values()].sort((a, b) => (a.person.birth_year ?? 0) - (b.person.birth_year ?? 0));

// year headers interleaved into the date-sorted entries
type Item = { type: 'year'; year: number | null } | Entry;
const items: Item[] = [];
let lastYear: number | null | undefined = undefined;
for (const e of entries) {
	const y = Number(e.date.slice(0, 4)) || null;
	if (y !== lastYear) { items.push({ type: 'year', year: y }); lastYear = y; }
	items.push(e);
}

const subtitle = `${results.length} results across the family`;
---

<Layout title="All Races" subtitle={subtitle}>
	<div class="people-row">
		{people.map(({ person, count }) => (
			<a class="person-link" href={`/people/${person.slug}`}>
				<Avatar src={person.avatar_url} name={person.full_name} size={36} />
				<span class="pl-name">{person.full_name.split(' ')[0]}</span>
				<span class="pl-count">{count}</span>
			</a>
		))}
	</div>

	{
		items.length === 0 ? (
			<div class="empty">No results recorded yet.</div>
		) : (
			<div class="results">
				{items.map((it) =>
					it.type === 'year' ? (
						<div class="year-header"><span>{it.year ?? '—'}</span></div>
					) : it.type === 'meet' ? (
						<MeetCard entry={it} prCtx={prCtx} showPerson />
					) : it.type === 'race' ? (
						<RaceGroupCard entry={it} prCtx={prCtx} />
					) : (
						<ResultRow r={it.r} pr={prCtx.prBadge(it.r)} aw={award(it.r)} showPerson />
					),
				)}
			</div>
		)
	}
</Layout>

<style>
	/* family avatar links — click a person to open their page (not a filter) */
	.people-row { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-bottom: 1.9rem; }
	.person-link { display: flex; align-items: center; gap: 0.6rem; background: var(--surface); border: 1px solid var(--border); border-radius: 999px; padding: 0.3rem 0.95rem 0.3rem 0.35rem; box-shadow: var(--shadow); color: var(--text); transition: border-color 0.12s, background 0.12s; }
	.person-link:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 9%, var(--surface)); text-decoration: none; }
	.pl-name { font-family: var(--font-display); font-weight: 400; font-size: 1.15rem; letter-spacing: 0.03em; }
	.pl-count { font-family: var(--font-mono); font-size: 0.66rem; color: var(--muted); background: var(--surface-2); border-radius: 999px; padding: 0.12rem 0.5rem; }

	/* .results + .year-header live in Layout.astro */
</style>
