---
import Layout from '../../layouts/Layout.astro';
import ResultMarks from '../../components/ResultMarks.astro';
import ResultPlaces from '../../components/ResultPlaces.astro';
import EventChip from '../../components/EventChip.astro';
import Avatar from '../../components/Avatar.astro';
import PrBadge from '../../components/PrBadge.astro';
import PrTime from '../../components/PrTime.astro';
import PodiumMedal from '../../components/PodiumMedal.astro';
import CategoryTag from '../../components/CategoryTag.astro';
import { getRaceBySlug, getAllFamilyResults } from '../../lib/queries';
import { familyTracks, recurringRivals, splitLabels } from '../../lib/compare';
import { categoryOf } from '../../lib/categories';
import { type Result, type Split } from '../../lib/types';
import {
	formatTime,
	formatDelta,
	deltaDirection,
	placement,
	isPodium,
	formatDistance,
	legPace,
	pacePer100m,
	legIcon,
	legColor,
	formatFullDate,
	formatSwimTime,
	parseSwimEvent,
	swimEventKey,
	abbrevDivision,
	swimDivision,
	divisionRank,
} from '../../lib/format';

const { slug } = Astro.params;
const data = slug ? await getRaceBySlug(slug) : null;
if (!data) return new Response('Race not found', { status: 404 });
const { race, editions } = data;

// Swimming doesn't fit the year-over-year track model (a swimmer has many event
// results per meet, not one finish). It gets its own per-meet, split-by-person view.
const swim = race.sport === 'swim_meet';
const tracks = swim ? [] : familyTracks(editions);
const rivalries = swim ? [] : recurringRivals(editions);

// ---- Swim meet view: each edition (meet) grouped by family swimmer ----------
const STROKE_ORDER: Record<string, number> = { free: 0, back: 1, breast: 2, fly: 3, im: 4, other: 5 };
const eventOrder = (r: Result) => {
	const ev = parseSwimEvent(r.event);
	return (ev.isRelay ? 1000 : 0) + (STROKE_ORDER[ev.strokeKey] ?? 9) * 100 + (ev.distance ?? 0) / 100;
};
const swimCs = (r: Result) => r.finish_time_cs ?? (r.finish_time_seconds != null ? r.finish_time_seconds * 100 : null);
const swimMeets = swim
	? [...editions].sort((a, b) => b.year - a.year).map((ed) => {
			const byPerson = new Map<string, { person: NonNullable<(typeof ed.result)[number]['person']>; events: Result[] }>();
			for (const r of ed.result) {
				if (!r.person) continue; // swim only stores family results
				const g = byPerson.get(r.person.id) ?? { person: r.person, events: [] };
				g.events.push(r);
				byPerson.set(r.person.id, g);
			}
			const swimmers = [...byPerson.values()]
				.map((s) => ({ ...s, events: [...s.events].sort((a, b) => eventOrder(a) - eventOrder(b)) }))
				.sort((a, b) => (a.person.birth_year ?? 0) - (b.person.birth_year ?? 0)); // oldest first
			return { ed, swimmers };
		})
	: [];

// A PR star on this meet means best-EVER for that swimmer + event, so we need
// their whole swim history (each weekly meet is a different race), not just this one.
const courseTok = (s: string | null | undefined) => (s ?? '').split(/\s+/)[0] || null;
const swimPrBest = new Map<string, number>(); // `${personId}|${eventKey}` -> best cs
if (swim) {
	for (const r of await getAllFamilyResults()) {
		if ((r.race_edition?.race?.sport ?? '') !== 'swim_meet' || r.status !== 'finished' || !r.person) continue;
		const cs = r.finish_time_cs ?? (r.finish_time_seconds != null ? r.finish_time_seconds * 100 : null);
		if (cs == null) continue;
		const key = `${r.person.id}|${swimEventKey(r.event, courseTok(r.race_edition?.distance_or_format))}`;
		const best = swimPrBest.get(key);
		if (best == null || cs < best) swimPrBest.set(key, cs);
	}
}
const isSwimPr = (r: Result, personId: string, course: string | null) => {
	if (r.status !== 'finished') return false;
	const cs = swimCs(r);
	return cs != null && swimPrBest.get(`${personId}|${swimEventKey(r.event, course)}`) === cs;
};

function awardInfo(result: Result | null): { tier: number; sub: string } | null {
	if (!result) return null;
	if (result.division_place != null && result.division_place <= 3)
		return { tier: result.division_place, sub: result.division ?? 'Division' };
	if (result.overall_place != null && result.overall_place <= 3)
		return { tier: result.overall_place, sub: 'Overall' };
	return null;
}

// Race header discipline summary (icon + distance) from the most recent family result.
const editionsDesc = [...editions].sort((a, b) => b.year - a.year);
let headerSplits: Split[] = [];
for (const ed of editionsDesc) {
	const fam = ed.result.find((r) => r.person?.is_family && r.split && r.split.length > 0);
	if (fam) { headerSplits = fam.split; break; }
}
const disciplines = headerSplits
	.filter((s) => /swim|bike|cycle|run/i.test(s.label))
	.map((s) => ({ label: s.label, icon: legIcon(s.label), dist: formatDistance(s.distance_m, s.distance_unit) }));
const format = editionsDesc[0]?.distance_or_format ?? null;

// The race's specific category — Sprint/Olympic/Kids Tri (split from the format + name)
// or the plain sport — tinted like the feed cards. Header tag, not the generic sport label.
const cat = categoryOf({ race_edition: { distance_or_format: format, race: { sport: race.sport, name: race.name } } });

const cmp = (m: number | null | undefined, t: number | null) => pacePer100m(m, t) ?? t;
---

<Layout title={race.name} subtitle={race.location ?? undefined} crumbs={[{ label: 'All Races', href: '/races' }]}>
	<div class="race-cat"><CategoryTag catKey={cat.key} label={cat.label} icon /></div>
	<section class="race-meta">
		{disciplines.length > 0 && (
			<div class="disciplines">
				{disciplines.map((d) => (
					<div class="disc" style={`--c:${legColor(d.label)}`}>
						<span class="disc-icon">{d.icon}</span>
						<span class="disc-text">
							<span class="disc-name">{d.label}</span>
							<span class="disc-dist">{d.dist ?? '—'}</span>
						</span>
					</div>
				))}
			</div>
		)}
	</section>
	{race.description && <p class="race-desc muted">{race.description}</p>}

	{swim && (
		swimMeets.length === 0 ? (
			<div class="empty">No meets recorded for this race yet.</div>
		) : (
			swimMeets.map((m) => (
				<section class="smeet">
					<div class="sm-head">
						<div class="sm-when">
							<span class="sm-yr">{m.ed.year}</span>
							<span class="sm-date">{formatFullDate(m.ed.date)}</span>
						</div>
						<div class="sm-tags">
							{m.ed.distance_or_format && <span class="sm-fmt">{m.ed.distance_or_format}</span>}
							{m.ed.source_url && <a class="sm-src" href={m.ed.source_url} target="_blank" rel="noopener">Full results ↗</a>}
						</div>
					</div>
					<div class="swimmers">
						{m.swimmers.map((s) => (
							<div class="swimmer">
								<div class="sw-head">
									<Avatar src={s.person.avatar_url} name={s.person.full_name} size={28} />
									{s.person.slug ? (
										<a class="sw-name" href={`/people/${s.person.slug}`}>{s.person.full_name}</a>
									) : (
										<span class="sw-name">{s.person.full_name}</span>
									)}
								</div>
								<div class="sw-events">
									{s.events.map((e) => {
										const place = e.division_place;
										const podium = place != null && isPodium(place) ? place : null;
										const dq = e.status !== 'finished';
										const pr = isSwimPr(e, s.person.id, courseTok(m.ed.distance_or_format));
										return (
											<div class={`sw-ev${dq ? ' is-dq' : ''}`}>
												<EventChip event={e.event} />
												<span class="sw-time">
													<span class="ev-timewrap">
														<ResultMarks medalTier={podium} medalSub={swimDivision(e.division)} pr={pr && !dq} compact />
														{dq ? (
															<span class="ev-dq">{e.status.toUpperCase()}</span>
														) : (
															<b class={`ev-t${pr ? ' is-pr' : ''}`}>{formatSwimTime(swimCs(e))}</b>
														)}
													</span>
												</span>
												<span class="sw-place">
													<ResultPlaces overallPlace={e.overall_place} overallFieldSize={e.overall_field_size} division={e.division} divisionPlace={e.division_place} />
												</span>
											</div>
										);
									})}
								</div>
							</div>
						))}
					</div>
				</section>
			))
		)
	)}

	{
		!swim && (tracks.length === 0 ? (
			<div class="empty">No family results recorded for this race yet.</div>
		) : (
			tracks.map((track) => {
				const cols = [...track.cells].reverse(); // newest first
				const labels = splitLabels(track);
				const rows = 5 + labels.length; // head, finish, splits, overall, division, foot
				return (
					<section class="track">
						<div class="track-head">
							<Avatar src={track.person.avatar_url} name={track.person.full_name} size={34} />
							<h2><a href={`/people/${track.person.slug}`}>{track.person.full_name}</a></h2>
							{track.prSeconds != null && (
								<PrTime time={formatTime(track.prSeconds)} caption={track.prYear ? String(track.prYear) : null} />
							)}
						</div>

						<div class="cards" style={`--rows:${rows}`}>
							{cols.map((c, i) => {
								const a = awardInfo(c.result);
								const older = cols[i + 1] ?? null;
								const fin = c.result?.status === 'finished' ? c.result.finish_time_seconds : null;
								const finOld = older?.result?.finish_time_seconds ?? null;
								const pr = fin != null && fin === track.prSeconds && c.year === track.prYear;
								return (
									<article class={`ycard${i === 0 ? ' latest' : ''}`}>
										{(a || pr) && (
											<div class="badges">
												{a && <PodiumMedal tier={a.tier} sub={abbrevDivision(a.sub)} />}
												{pr && <PrBadge />}
											</div>
										)}

										<div class="row head">
											<span class="yr">{c.year}</span>
											<span class="yh-sub">{formatFullDate(c.edition.date)}</span>
										</div>

										<div class="row finish">
											<span class="rl">Finish</span>
											<span class="rv">
												<b class={`big${pr ? ' is-pr' : ''}`}>{formatTime(fin)}</b>
												{fin != null && finOld != null && <span class={`delta ${deltaDirection(fin, finOld)}`}>{formatDelta(fin, finOld)}</span>}
											</span>
										</div>

										{labels.map((label) => {
											const s = c.splits.find((x) => x.label === label);
											const t = s?.segment_time_seconds ?? null;
											const oS = older?.splits.find((x) => x.label === label);
											const tOld = oS?.segment_time_seconds ?? null;
											const pace = legPace(s?.distance_m, t, s?.distance_unit);
											return (
												<div class="row">
													<span class="rl"><span class="ri" style={`color:${legColor(label)}`}>{legIcon(label)}</span>{label}</span>
													<span class="rv">
														<b>{formatTime(t)}</b>
														{pace && <span class="sub">{pace}</span>}
														{t != null && tOld != null && (
															<span class={`delta ${deltaDirection(cmp(s?.distance_m, t), cmp(oS?.distance_m, tOld))}`}>{formatDelta(t, tOld)}</span>
														)}
													</span>
												</div>
											);
										})}

										<div class="row">
											<span class="rl">Overall</span>
											<span class="rv"><b>{placement(c.result?.overall_place, c.result?.overall_field_size)}</b></span>
										</div>
										<div class="row">
											<span class="rl">Division</span>
											<span class="rv">
												<b>{divisionRank(c.result?.division, c.result?.division_place) || '—'}</b>
											</span>
										</div>

										<div class="row foot">
											{c.edition.source_url ? (
												<a href={c.edition.source_url} target="_blank" rel="noopener">Full results ↗</a>
											) : (
												<span class="muted small">No source link</span>
											)}
										</div>
									</article>
								);
							})}
						</div>
					</section>
				);
			})
		))
	}

	{
		rivalries.length > 0 && (
			<section class="rivalry">
				<h2>Familiar faces</h2>
				<p class="muted small">Competitors you keep lining up against in the same division.</p>
				<div class="grid cols-2">
					{rivalries.map((rv) =>
						rv.rivals.map((rival) => (
							<div class="card rival-card">
								<div class="rival-line"><strong>{rv.family.full_name}</strong><span class="muted"> vs </span><strong>{rival.competitor.full_name}</strong></div>
								<div class="muted small">{rv.division ?? 'same division'} · together in {rival.years.join(', ')}</div>
								{rival.bothPodiumYears.length > 0 && <div class="podium-note">🏅 Both on the podium in {rival.bothPodiumYears.join(', ')}</div>}
							</div>
						)),
					)}
				</div>
			</section>
		)
	}
</Layout>

<style>
	/* race header */
	.race-cat { margin: -0.5rem 0 1rem; }
	.race-meta { display: flex; align-items: stretch; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 1.6rem; }
	.disciplines { display: flex; gap: 0.7rem; flex-wrap: wrap; }
	.disc { display: flex; align-items: center; gap: 0.7rem; background: var(--surface); border: 1px solid var(--border); border-left: 3px solid var(--c, var(--border)); border-radius: 12px; padding: 0.45rem 1rem; }
	.disc-icon { font-size: 1.6rem; line-height: 1; color: var(--c, var(--text)); }
	.disc-text { display: flex; flex-direction: column; line-height: 1.05; }
	.disc-name { font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--faint); }
	.disc-dist { font-family: var(--font-display); font-size: 1.5rem; letter-spacing: 0.02em; }
	.race-desc { margin: -0.5rem 0 1.5rem; max-width: 60ch; }

	.track { margin-bottom: 2.75rem; }
	/* a clear per-person section header: avatar + name + a divider line */
	.track-head { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 1.2rem; padding-bottom: 0.6rem; border-bottom: 1px solid var(--border); }
	.track-head h2 { margin: 0; font-family: var(--font-display); font-weight: 400; font-size: 1.8rem; letter-spacing: 0.04em; }
	.track-head h2 a { color: var(--text); }
	.track-head h2 a:hover { color: var(--accent); text-decoration: none; }
	/* PR best-time + year lives in <PrTime/>: same tight star ↔ time gap as the feed rows. */

	/* standalone year cards, rows aligned via subgrid */
	.cards {
		display: grid;
		grid-auto-flow: column;
		grid-auto-columns: minmax(186px, 1fr);
		grid-template-rows: repeat(var(--rows), auto);
		gap: 0 1.35rem;
		overflow-x: auto;
		/* top padding leaves room for the badge pill that sits above each card */
		padding: 1.8rem 1.1rem 1.4rem;
	}
	.ycard {
		grid-row: 1 / -1;
		display: grid;
		grid-template-rows: subgrid;
		border: 1px solid var(--border);
		border-radius: 18px;
		background: linear-gradient(180deg, var(--surface-2), var(--surface) 130px);
		position: relative;
		box-shadow: var(--shadow);
	}
	.ycard.latest { border-color: color-mix(in srgb, var(--accent) 50%, transparent); box-shadow: var(--shadow), 0 0 0 1px color-mix(in srgb, var(--accent) 45%, transparent); }

	.row { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.6rem; padding: 0.5rem 0.95rem; border-bottom: 1px solid var(--border); }
	.row:last-child { border-bottom: none; }
	.row.head { flex-direction: column; align-items: stretch; gap: 0.15rem; padding-top: 2rem; padding-bottom: 0.75rem; }
	.row.head .yr { font-family: var(--font-display); font-weight: 400; font-size: 2.7rem; letter-spacing: 0.03em; line-height: 0.85; }
	.yh-sub { font-family: var(--font-mono); font-size: 0.63rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--faint); }

	.rl { font-family: var(--font-mono); color: var(--muted); font-size: 0.67rem; letter-spacing: 0.08em; text-transform: uppercase; display: flex; align-items: center; gap: 0.4rem; white-space: nowrap; padding-top: 0.32rem; }
	.ri { font-size: 1.1rem; }
	.rv { text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 0.1rem; }
	.rv b { font-family: var(--font-mono); font-weight: 600; font-size: 0.95rem; display: inline-flex; align-items: center; gap: 0.35rem; }
	.rv .big { font-family: var(--font-display); font-weight: 400; font-size: 2.1rem; letter-spacing: 0.02em; line-height: 1; }
	.rv .big.is-pr { color: var(--gold); }
	.row.finish { background: color-mix(in srgb, var(--accent) 5%, transparent); }
	.sub { font-family: var(--font-mono); font-size: 0.66rem; color: var(--faint); }
	.delta { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 600; }
	.delta.faster { color: var(--faster); }
	.delta.slower { color: var(--slower); }
	.delta.same { color: var(--faint); }
	.row.foot { padding: 0.7rem 0.95rem; }
	.row.foot a { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.06em; text-transform: uppercase; }
	.small { font-size: 0.85rem; }

	/* award + PR markers (shared PodiumMedal/PrBadge), centered above each year card */
	.badges { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); z-index: 4; display: flex; flex-direction: row; gap: 0.7rem; align-items: center; background: var(--surface-2); border: 1px solid var(--border); border-radius: 999px; padding: 0.25rem 0.7rem; box-shadow: var(--shadow); }

	.rivalry { margin-top: 1rem; }
	.rivalry h2 { font-family: var(--font-display); font-weight: 400; font-size: 1.7rem; letter-spacing: 0.03em; margin: 0 0 0.25rem; }
	.rivalry p { margin: 0 0 1rem; }
	.rival-card { padding: 1rem 1.1rem; }
	.rival-line { margin-bottom: 0.25rem; }
	.podium-note { margin-top: 0.5rem; color: var(--gold); font-size: 0.88rem; }

	/* ---- Swim meet view: one block per meet, split by swimmer ---- */
	.smeet { margin-bottom: 2.4rem; }
	.sm-head { display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 0.6rem 1rem; margin-bottom: 1.1rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--border); }
	.sm-when { display: flex; align-items: baseline; gap: 0.8rem; }
	.sm-yr { font-family: var(--font-display); font-weight: 400; font-size: 2.3rem; letter-spacing: 0.03em; color: var(--swim); line-height: 0.9; }
	.sm-date { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--faint); }
	.sm-tags { display: flex; align-items: center; gap: 0.7rem; }
	.sm-fmt { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); border: 1px solid var(--border); border-radius: 999px; padding: 0.2rem 0.7rem; }
	.sm-src { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.06em; text-transform: uppercase; }

	.swimmers { display: grid; grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); gap: 1rem; }
	.swimmer { background: linear-gradient(180deg, var(--surface-2), var(--surface) 60px); border: 1px solid var(--border); border-radius: 14px; box-shadow: var(--shadow); overflow: hidden; }
	.sw-head { display: flex; align-items: center; gap: 0.55rem; padding: 0.6rem 1rem; border-bottom: 1px solid var(--border); background: color-mix(in srgb, var(--swim) 10%, transparent); }
	.sw-name { font-family: var(--font-display); font-weight: 400; font-size: 1.45rem; letter-spacing: 0.03em; color: var(--text); }
	.sw-name:hover { color: var(--swim); text-decoration: none; }

	/* Per-event rows: real subgrid rows (not display:contents) so the event name,
	   time, and standing line up across every event and the row separator is one
	   clean line. Anatomy mirrors the feed MeetCard row: EventChip · time (marks to
	   its left) · ResultPlaces standing (place-first "8th · 8&U•B"). */
	.sw-events { display: grid; grid-template-columns: minmax(0, 1fr) max-content max-content; padding: 0.3rem 1rem 0.6rem; }
	.sw-ev { display: grid; grid-template-columns: subgrid; grid-column: 1 / -1; align-items: center; column-gap: 0.7rem; padding: 0.34rem 0; border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent); }
	.sw-ev:first-child { border-top: none; }
	/* time cell is the anchor; the medal/PR marks sit just left of it */
	.sw-time { position: relative; display: flex; align-items: center; justify-content: flex-end; white-space: nowrap; }
	.ev-timewrap { position: relative; width: max-content; }
	.ev-t { font-family: var(--font-display); font-weight: 400; font-size: var(--fs-time-sm); letter-spacing: var(--ls-tight); line-height: 1; }
	.ev-t.is-pr { color: var(--gold); }
	.ev-dq { font-family: var(--font-display); font-weight: 400; font-size: var(--fs-time-sm); letter-spacing: var(--ls-tight); line-height: 1; color: var(--slower); }
	.sw-place { display: flex; flex-direction: column; justify-content: center; }
	.sw-ev.is-dq .evchip { color: var(--muted); }
</style>
