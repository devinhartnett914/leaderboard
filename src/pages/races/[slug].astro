---
import Layout from '../../layouts/Layout.astro';
import { getRaceBySlug } from '../../lib/queries';
import { familyTracks, recurringRivals, splitLabels, type FamilyTrack } from '../../lib/compare';
import { SPORT_LABELS } from '../../lib/types';
import {
	formatTime,
	formatDelta,
	deltaDirection,
	placement,
	ordinal,
	isPodium,
	formatDistance,
	legPace,
	pacePer100m,
} from '../../lib/format';

const { slug } = Astro.params;
const data = slug ? await getRaceBySlug(slug) : null;

if (!data) {
	return new Response('Race not found', { status: 404 });
}
const { race, editions } = data;
const tracks = familyTracks(editions);
const rivalries = recurringRivals(editions);
const years = [...editions].sort((a, b) => a.year - b.year).map((e) => e.year);

interface Cell {
	time: number | null;
	distance_m: number | null;
	unit: string | null;
}
interface MetricRow {
	label: string;
	kind: 'finish' | 'leg';
	cells: Cell[];
	rowDistance: string | null; // shown in the label when constant across years
}

function metricRows(track: FamilyTrack): MetricRow[] {
	const rows: MetricRow[] = [
		{
			label: 'Finish',
			kind: 'finish',
			rowDistance: null,
			cells: track.cells.map((c) => ({
				time: c.result?.status === 'finished' ? c.result.finish_time_seconds : null,
				distance_m: null,
				unit: null,
			})),
		},
	];
	for (const label of splitLabels(track)) {
		const cells: Cell[] = track.cells.map((c) => {
			const s = c.splits.find((x) => x.label === label);
			return { time: s?.segment_time_seconds ?? null, distance_m: s?.distance_m ?? null, unit: s?.distance_unit ?? null };
		});
		// if every leg with a distance shows the same value, hoist it into the label
		const distances = [...new Set(cells.map((c) => formatDistance(c.distance_m, c.unit)).filter(Boolean))];
		rows.push({ label, kind: 'leg', cells, rowDistance: distances.length === 1 ? distances[0]! : null });
	}
	return rows;
}

// comparable: lower = faster. Uses pace/100m when a distance is known, else raw time.
const comparable = (c: Cell): number | null => pacePer100m(c.distance_m, c.time) ?? c.time;
---

<Layout title={race.name} subtitle={[SPORT_LABELS[race.sport], race.location].filter(Boolean).join(' · ')}>
	{race.description && <p class="race-desc muted">{race.description}</p>}

	<section class="editions">
		{
			[...editions]
				.sort((a, b) => b.year - a.year)
				.map((ed) => (
					<div class="card edition-card">
						<div class="year">{ed.year}</div>
						<div class="muted small">
							{ed.distance_or_format ?? ''}
							{ed.date ? ` · ${ed.date}` : ''}
						</div>
						{ed.source_url && (
							<a class="small" href={ed.source_url} target="_blank" rel="noopener">
								Full results ↗
							</a>
						)}
					</div>
				))
		}
	</section>

	{
		tracks.length === 0 ? (
			<div class="empty">No family results recorded for this race yet.</div>
		) : (
			tracks.map((track) => (
				<section class="track">
					<div class="track-head">
						<h2>{track.person.full_name}</h2>
						{track.prSeconds != null && (
							<span class="pill gold">PR {formatTime(track.prSeconds)} · {track.prYear}</span>
						)}
					</div>
					<div class="card table-card">
						<table>
							<thead>
								<tr>
									<th>Leg</th>
									{years.map((y) => (
										<th class="num-col">{y}</th>
									))}
								</tr>
							</thead>
							<tbody>
								{metricRows(track).map((row) => (
									<tr class={row.kind === 'finish' ? 'finish-row' : 'leg-row'}>
										<th scope="row">
											{row.label}
											{row.rowDistance && <span class="row-dist">{row.rowDistance}</span>}
										</th>
										{row.cells.map((cell, i) => {
											const prev = i > 0 ? row.cells[i - 1] : null;
											const dir = deltaDirection(comparable(cell), prev ? comparable(prev) : null);
											const pace = legPace(cell.distance_m, cell.time, cell.unit);
											const cellDist = row.rowDistance ? null : formatDistance(cell.distance_m, cell.unit);
											const isPrCell =
												row.kind === 'finish' && cell.time != null && cell.time === track.prSeconds && years[i] === track.prYear;
											return (
												<td class="num-col">
													<span class={isPrCell ? 'pr-time' : ''}>{formatTime(cell.time)}</span>
													{row.kind === 'finish'
														? prev && <span class={`delta ${dir}`}>{formatDelta(cell.time, prev.time)}</span>
														: cell.time != null && (
																<span class={`pace ${dir}`}>
																	{pace ?? ''}
																	{cellDist ? ` · ${cellDist}` : ''}
																</span>
															)}
												</td>
											);
										})}
									</tr>
								))}
								<tr class="meta-row">
									<th scope="row">Overall</th>
									{track.cells.map((c) => (
										<td class="num-col muted">{placement(c.result?.overall_place, c.result?.overall_field_size)}</td>
									))}
								</tr>
								<tr class="meta-row">
									<th scope="row">Division</th>
									{track.cells.map((c) => (
										<td class="num-col muted">
											{c.result?.division ? `${c.result.division} · ${ordinal(c.result.division_place)}` : '—'}
											{isPodium(c.result?.division_place) && ' 🏅'}
										</td>
									))}
								</tr>
							</tbody>
						</table>
					</div>
				</section>
			))
		)
	}

	{
		rivalries.length > 0 && (
			<section class="rivalry">
				<h2>Familiar faces</h2>
				<p class="muted small">Competitors you keep lining up against in the same division.</p>
				<div class="grid cols-2">
					{rivalries.map((rv) =>
						rv.rivals.map((rival) => (
							<div class="card rival-card">
								<div class="rival-line">
									<strong>{rv.family.full_name}</strong>
									<span class="muted"> &nbsp;vs&nbsp; </span>
									<strong>{rival.competitor.full_name}</strong>
								</div>
								<div class="muted small">
									{rv.division ?? 'same division'} · together in {rival.years.join(', ')}
								</div>
								{rival.bothPodiumYears.length > 0 && (
									<div class="podium-note">🏅 Both on the podium in {rival.bothPodiumYears.join(', ')}</div>
								)}
							</div>
						)),
					)}
				</div>
			</section>
		)
	}
</Layout>

<style>
	.race-desc { margin: -0.5rem 0 1.5rem; max-width: 60ch; }
	.editions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2rem; }
	.edition-card { padding: 0.8rem 1rem; min-width: 150px; }
	.edition-card .year { font-size: 1.25rem; font-weight: 700; }
	.small { font-size: 0.85rem; }

	.track { margin-bottom: 2.25rem; }
	.track-head { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.85rem; }
	.track-head h2 { margin: 0; font-size: 1.2rem; }

	.table-card { padding: 0; overflow-x: auto; }
	.num-col { text-align: right; }
	td.num-col { white-space: nowrap; vertical-align: top; }
	.row-dist { display: block; font-size: 0.72rem; color: var(--muted); font-weight: 400; text-transform: none; letter-spacing: 0; }
	.delta, .pace { display: block; font-size: 0.78rem; margin-top: 0.1rem; }
	.pace { color: var(--muted); }
	.pace.faster { color: var(--faster); }
	.pace.slower { color: var(--slower); }
	.finish-row th, .finish-row td { font-weight: 600; font-size: 1.02rem; }
	.pr-time { color: var(--gold); }
	.meta-row td, .meta-row th { font-size: 0.85rem; }

	.rivalry { margin-top: 1rem; }
	.rivalry h2 { font-size: 1.2rem; margin: 0 0 0.25rem; }
	.rivalry p { margin: 0 0 1rem; }
	.rival-card { padding: 1rem 1.1rem; }
	.rival-line { margin-bottom: 0.25rem; }
	.podium-note { margin-top: 0.5rem; color: var(--gold); font-size: 0.88rem; }

	/* The year-over-year matrix is inherently wide, so it scrolls sideways on
	   phones — pin the leg-label column so you don't lose track of the row. */
	@media (max-width: 640px) {
		.track table th[scope='row'],
		.track thead th:first-child {
			position: sticky;
			left: 0;
			z-index: 1;
			background: var(--surface);
			border-right: 1px solid var(--border);
		}
		.editions { gap: 0.5rem; }
		.edition-card { min-width: 0; flex: 1 1 calc(50% - 0.5rem); }
	}
</style>
