---
// THROWAWAY preview (DEV-30) — compare the four all-races feed-card head layouts tried in
// this ticket, so a winner can be picked before touching the real cards. Visit /dev30-preview.
// Delete this page + src/components/Dev30Card.astro once a layout is chosen, then implement the
// winner in ResultRow / MeetCard / RaceGroupCard.
import Layout from '../layouts/Layout.astro';
import Dev30Card from '../components/Dev30Card.astro';
import { getFamilyMembers } from '../lib/queries';
import type { Person } from '../lib/types';

// Fetch real family members so the preview uses actual avatar photos, not initials placeholders.
const family = await getFamilyMembers();
const findP = (slug: string): Person =>
	family.find((p) => p.slug === slug) ?? { id: slug, full_name: slug, slug, avatar_url: null, is_family: true, gender: null, birth_date: null, birth_year: null };

const sierra = findP('sierra-hartnett');
const aurora = findP('aurora-hartnett');
const devin = findP('devin-hartnett');

const variants = [
	{
		key: 'A' as const,
		title: 'A — Location IN the type strip (edge color)',
		note: 'Location folded into the colored type tag: 🏊 SWIM MEET · RESTON, VA (same edge color). Racer stays in the standard sub-meta line below the race name.',
	},
	{
		key: 'B' as const,
		title: 'B — Location top-right corner, small gray',
		note: 'Type tag stays clean (just type + distance). Racer stays in the sub-meta line. Location parks in the top-right corner of the card, small gray mono.',
	},
	{
		key: 'C' as const,
		title: 'C — Racer above title, location pipe-beside type (gray)',
		note: 'Racer moves above the race title. Race type + gray pipe + location below the name: 🏊 SWIM MEET | RESTON, VA.',
	},
	{
		key: 'D' as const,
		title: 'D — Large avatar left · name + TYPE | location right',
		note: 'Racer becomes a large avatar on the far left (full height of the name + tags block), with name and TYPE | LOCATION to its right. Stacked avatars for multi-racer.',
	},
];

// two representative examples: a single-racer swim meet and a multi-racer triathlon
const examples = [
	{
		label: 'Single racer · swim meet',
		catKey: 'swim_meet', name: 'Reston Masters Invitational', type: 'Swim Meet',
		location: 'Reston, VA', racers: [sierra],
		date: '2026-03-14', year: 2026,
		finish: '27.91', pr: true, medalTier: 1, medalSub: 'Girls 13-14',
		division: 'Girls 13-14', divisionPlace: 1, overallPlace: 4, overallFieldSize: 38,
	},
	{
		label: 'Multiple racers · triathlon',
		catKey: 'olympic', name: 'Luray International Triathlon', type: 'Olympic Tri',
		location: 'Luray, VA', racers: [sierra, aurora, devin],
		date: '2025-08-17', year: 2025,
		finish: '2:41:09', pr: false, medalTier: 2, medalSub: 'F40-44',
		division: 'F40-44', divisionPlace: 2, overallPlace: 51, overallFieldSize: 412,
	},
];
---

<Layout title="DEV-30 — all-races card head layout">
	<section class="hero">
		<div class="eyebrow">Throwaway preview · DEV-30</div>
		<h1>All-races card<br /><span>location + racer layout</span></h1>
		<p class="muted">
			Four options, each with its <strong>original layout</strong> — pick the location treatment you want
			and I'll ship it to the real cards and delete this page.
			Each block shows the same two cards — a single-racer swim meet and a multi-racer triathlon.
		</p>
	</section>

	{
		variants.map((v) => (
			<section class="block">
				<div class="section-head">
					<h2>{v.title}</h2>
				</div>
				<p class="note">{v.note}</p>
				<div class="results">
					{examples.map((ex) => (
						<Dev30Card
							variant={v.key}
							catKey={ex.catKey}
							name={ex.name}
							type={ex.type}
							location={ex.location}
							racers={ex.racers}
							date={ex.date}
							year={ex.year}
							finish={ex.finish}
							pr={ex.pr}
							medalTier={ex.medalTier}
							medalSub={ex.medalSub}
							division={ex.division}
							divisionPlace={ex.divisionPlace}
							overallPlace={ex.overallPlace}
							overallFieldSize={ex.overallFieldSize}
						/>
					))}
				</div>
			</section>
		))
	}
</Layout>

<style>
	.hero { margin: 1rem 0 2.5rem; }
	.eyebrow { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
	.hero h1 { margin: 0 0 1rem; font-family: var(--font-display); font-weight: 400; font-size: clamp(2.5rem, 7vw, 4rem); line-height: 0.9; letter-spacing: 0.02em; }
	.hero h1 span { color: var(--accent); }
	.hero p { margin: 0; max-width: 70ch; }
	.block { margin-bottom: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--border); }
	.section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 0.4rem; flex-wrap: wrap; }
	.section-head h2 { margin: 0; font-family: var(--font-display); font-weight: 400; font-size: 1.7rem; letter-spacing: 0.04em; }
	.note { margin: 0 0 1.1rem; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em; color: var(--faint); max-width: 80ch; }
</style>
