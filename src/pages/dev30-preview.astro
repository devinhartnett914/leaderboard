---
// THROWAWAY preview (DEV-30) — compare the four all-races feed-card head layouts tried in
// this ticket, so a winner can be picked before touching the real cards. Visit /dev30-preview.
// Delete this page + src/components/Dev30Card.astro once a layout is chosen, then implement the
// winner in ResultRow / MeetCard / RaceGroupCard. Sample data (initials avatars) — the point is
// the HEAD layout (racer + name + type + location); the right-hand finish/standing is constant.
import Layout from '../layouts/Layout.astro';
import Dev30Card from '../components/Dev30Card.astro';

// Round 5: all options now share the large-avatar-left layout (per feedback).
// The comparison is PURELY about WHERE the location text appears.
const variants = [
	{ key: 'A', title: 'A — Location IN the type strip (edge color)', note: 'Location folded into the colored type tag: SWIM MEET · RESTON, VA (same edge color). Avatar on the far left.' },
	{ key: 'B', title: 'B — Location top-right corner, small gray', note: 'Type tag stays clean (just the type). Location parks in the top-right corner of the card, small gray mono. Avatar on the far left.' },
	{ key: 'C', title: 'C — Location on its own line, below the type tag', note: 'Type tag is clean. Location appears as a separate small gray mono line directly below it. Avatar on the far left.' },
	{ key: 'D', title: 'D — Location pipe-separated inline with type (gray)', note: 'Location follows the type tag inline, gray, pipe-separated: SWIM MEET | RESTON, VA. Avatar on the far left.' },
] as const;

const sierra = { full_name: 'Sierra Hartnett', slug: 'sierra-hartnett', avatar_url: null };
const aurora = { full_name: 'Aurora Hartnett', slug: 'aurora-hartnett', avatar_url: null };
const devin = { full_name: 'Devin Hartnett', slug: 'devin-hartnett', avatar_url: null };

// two representative examples: a single-racer swim meet and a multi-racer triathlon
const examples = [
	{
		label: 'Single racer · swim meet',
		card: {
			catKey: 'swim_meet', name: 'Reston Masters Invitational', type: 'Swim Meet', distance: null,
			location: 'Reston, VA', racers: [sierra], date: '2026-03-14', year: 2026,
			finish: '27.91', pr: true, medalTier: 1, medalSub: 'Girls 13-14',
			division: 'Girls 13-14', divisionPlace: 1, overallPlace: 4, overallFieldSize: 38,
		},
	},
	{
		label: 'Multiple racers · triathlon',
		card: {
			catKey: 'olympic', name: 'Luray International Triathlon', type: 'Olympic Tri', distance: null,
			location: 'Luray, VA', racers: [sierra, aurora, devin], date: '2025-08-17', year: 2025,
			finish: '2:41:09', pr: false, medalTier: 2, medalSub: 'F40-44',
			division: 'F40-44', divisionPlace: 2, overallPlace: 51, overallFieldSize: 412,
		},
	},
] as const;
---

<Layout title="DEV-30 — all-races card head layout">
	<section class="hero">
		<div class="eyebrow">Throwaway preview · DEV-30</div>
		<h1>All-races card<br /><span>location + racer layout</span></h1>
		<p class="muted">
			All four options now use the <strong>large avatar on the far left</strong> so you can see them all clearly.
			The only thing that changes between A/B/C/D is <strong>where the location text appears</strong>.
			Each block shows the same two cards — a single-racer swim meet and a multi-racer triathlon — so
			you can see how each option handles one avatar vs. stacked avatars. Pick a location treatment and
			I'll ship it on the real cards and delete this page.
		</p>
	</section>

	{
		variants.map((v) => (
			<section class="block">
				<div class="section-head">
					<h2>{v.title}</h2>
				</div>
				<p class="note">{v.note}</p>
				<div class="results">
					{examples.map((ex) => (
						<Dev30Card variant={v.key} {...ex.card} />
					))}
				</div>
			</section>
		))
	}
</Layout>

<style>
	.hero { margin: 1rem 0 2.5rem; }
	.eyebrow { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
	.hero h1 { margin: 0 0 1rem; font-family: var(--font-display); font-weight: 400; font-size: clamp(2.5rem, 7vw, 4rem); line-height: 0.9; letter-spacing: 0.02em; }
	.hero h1 span { color: var(--accent); }
	.hero p { margin: 0; max-width: 70ch; }
	.block { margin-bottom: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--border); }
	.section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 0.4rem; flex-wrap: wrap; }
	.section-head h2 { margin: 0; font-family: var(--font-display); font-weight: 400; font-size: 1.7rem; letter-spacing: 0.04em; }
	.note { margin: 0 0 1.1rem; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em; color: var(--faint); max-width: 80ch; }
</style>
