---
import Layout from '../../layouts/Layout.astro';
import ResultMarks from '../../components/ResultMarks.astro';
import { getPersonBySlug, type ResultWithEdition } from '../../lib/queries';
import { SPORT_LABELS, type Sport } from '../../lib/types';
import { categoryOf, CAT_COLOR, CAT_ICON } from '../../lib/categories';
import { formatTime, placement, ordinal, legPace, legIcon, legColor, currentAge, formatSwimTime, parseSwimEvent, swimEventKey, swimEventSlug, abbrevDivision } from '../../lib/format';

const { slug } = Astro.params;
const data = slug ? await getPersonBySlug(slug) : null;
if (!data) return new Response('Person not found', { status: 404 });
const { person, results } = data;

const MEDAL = ['🥇', '🥈', '🥉'];
const MEDAL_LABEL = ['1st', '2nd', '3rd'];
const MEDAL_COLOR = ['#f0b400', '#b4bfca', '#cf7d44'];
const MON = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

const isSwim = (r: ResultWithEdition) => (r.race_edition?.race?.sport ?? 'other') === 'swim_meet';
const courseOf = (r: ResultWithEdition) => ((r.race_edition?.distance_or_format ?? '').split(/\s+/)[0] || null);
/** exact swim time in hundredths, falling back to rounded whole seconds */
const swimCs = (r: ResultWithEdition) => r.finish_time_cs ?? (r.finish_time_seconds != null ? r.finish_time_seconds * 100 : null);
/** strip the trailing heat token off a division → the age group: "9-10 C" → "9-10" */
const ageGroupOf = (div: string | null | undefined) => (div ?? '').replace(/\s+(A|B|C|D|Non-?Award)\b.*$/i, '').trim() || null;

function podiumPlace(r: ResultWithEdition): number | null {
	if (r.division_place != null && r.division_place <= 3) return r.division_place;
	if (r.overall_place != null && r.overall_place <= 3) return r.overall_place;
	return null;
}
// Podium medallion (same idea as the race page): division podium wins, else overall.
function award(r: ResultWithEdition): { tier: number; sub: string } | null {
	if (r.division_place != null && r.division_place <= 3) return { tier: r.division_place, sub: r.division ?? 'Division' };
	if (r.overall_place != null && r.overall_place <= 3) return { tier: r.overall_place, sub: 'Overall' };
	return null;
}
function dateParts(iso: string | null | undefined, fy: number | null | undefined) {
	const m = iso?.match(/^(\d{4})-(\d{2})-(\d{2})/);
	if (m) return { mon: MON[Number(m[2]) - 1], day: String(Number(m[3])), year: m[1] };
	return { mon: '', day: '', year: fy ? String(fy) : '' };
}

const sortKey = (r: ResultWithEdition) => r.race_edition?.date ?? `${r.race_edition?.year ?? 0}-00-00`;

// ---- Swim: per-event best (drives the gold time + PR star on each event row).
// Identity is course + distance + stroke (NOT age group), so a 25 Back keeps the
// same PR line as the kid ages up. The full progression lives on /swim/[event].
const swimResults = results.filter(isSwim);
const prByEventKey = new Map<string, number>(); // swimEventKey -> best cs (finished only)
for (const r of swimResults) {
	if (r.status !== 'finished') continue;
	const cs = swimCs(r);
	if (cs == null) continue;
	const k = swimEventKey(r.event, courseOf(r));
	const best = prByEventKey.get(k);
	if (best == null || cs < best) prByEventKey.set(k, cs);
}
const isSwimPr = (r: ResultWithEdition) => {
	if (r.status !== 'finished') return false;
	const cs = swimCs(r);
	return cs != null && prByEventKey.get(swimEventKey(r.event, courseOf(r))) === cs;
};

// Per-series PR (best at this specific recurring race) + how many times raced here.
const prByRace = new Map<string, number>();
const countByRace = new Map<string, number>();
for (const r of results) {
	if (isSwim(r)) continue;
	const raceId = r.race_edition?.race?.id;
	if (!raceId || r.status !== 'finished' || r.finish_time_seconds == null) continue;
	countByRace.set(raceId, (countByRace.get(raceId) ?? 0) + 1);
	const best = prByRace.get(raceId);
	if (best == null || r.finish_time_seconds < best) prByRace.set(raceId, r.finish_time_seconds);
}

// True distance PR for running: your fastest 5K / 10K / Half across *every* series,
// not just within one race. Distance comes from the race name / format, since the
// split distances aren't reliable for runs. Keyed by sport so a trail 5K and a road
// 5K each keep their own PR.
function runDistance(r: ResultWithEdition): string | null {
	const sport = r.race_edition?.race?.sport;
	if (sport !== 'road_run' && sport !== 'trail_run') return null;
	const s = `${r.race_edition?.distance_or_format ?? ''} ${r.race_edition?.race?.name ?? ''}`.toLowerCase();
	if (/\bhalf\b|13\.1/.test(s)) return 'Half';
	if (/\bmarathon\b|26\.2/.test(s)) return 'Marathon';
	if (/\b5k\b/.test(s)) return '5K';
	if (/\b10k\b/.test(s)) return '10K';
	if (/\b15k\b/.test(s)) return '15K';
	if (/\b8k\b/.test(s)) return '8K';
	if (/five mile|\b5 ?mile/.test(s)) return '5 Mile';
	if (/ten mile|\b10 ?mile/.test(s)) return '10 Mile';
	if (/one mile|\b1 ?mile/.test(s)) return '1 Mile';
	return null;
}
const distKey = (r: ResultWithEdition) => {
	const d = runDistance(r);
	return d ? `${r.race_edition?.race?.sport}|${d}` : null;
};
const prByDist = new Map<string, number>();
for (const r of results) {
	const k = distKey(r);
	if (!k || r.status !== 'finished' || r.finish_time_seconds == null) continue;
	const best = prByDist.get(k);
	if (best == null || r.finish_time_seconds < best) prByDist.set(k, r.finish_time_seconds);
}

// Which PR badge (if any) a result earns. Gold = the headline PR (sets the time gold);
// a recurring series' own best still shows as a quieter "Series PR" when a different
// race holds the distance PR. (Swim PRs are handled separately, per-event.)
function prBadge(r: ResultWithEdition): { gold: boolean; label: string } | null {
	if (r.status !== 'finished' || r.finish_time_seconds == null) return null;
	const raceId = r.race_edition?.race?.id;
	const sport = r.race_edition?.race?.sport;
	const t = r.finish_time_seconds;
	const k = distKey(r);
	const dist = runDistance(r);
	if (k && prByDist.get(k) === t) return { gold: true, label: `${dist} PR` };
	const recurring = raceId != null && (countByRace.get(raceId) ?? 0) >= 2;
	if (recurring && raceId != null && prByRace.get(raceId) === t) {
		return k ? { gold: false, label: 'Series PR' } : { gold: true, label: 'PR' };
	}
	// non-running one-offs keep the simple per-race PR star
	if (sport !== 'road_run' && sport !== 'trail_run' && raceId != null && prByRace.get(raceId) === t) {
		return { gold: true, label: 'PR' };
	}
	return null;
}

// ---- Feed entries: tri/run = one card per result; swim = one card per meet --
type CardEntry = { type: 'card'; r: ResultWithEdition; date: string };
type MeetEntry = { type: 'meet'; key: string; events: ResultWithEdition[]; date: string };
const entries: (CardEntry | MeetEntry)[] = [];
const swimByEdition = new Map<string, ResultWithEdition[]>();
for (const r of results) {
	if (isSwim(r)) {
		const k = r.race_edition_id;
		(swimByEdition.get(k) ?? swimByEdition.set(k, []).get(k)!).push(r);
	} else {
		entries.push({ type: 'card', r, date: sortKey(r) });
	}
}
const STROKE_ORDER: Record<string, number> = { free: 0, back: 1, breast: 2, fly: 3, im: 4, other: 5 };
const EVENT_ORDER = (r: ResultWithEdition) => {
	const ev = parseSwimEvent(r.event);
	return (ev.isRelay ? 1000 : 0) + (STROKE_ORDER[ev.strokeKey] ?? 9) * 100 + (ev.distance ?? 0) / 100;
};
for (const [key, evs] of swimByEdition) {
	const sorted = [...evs].sort((a, b) => EVENT_ORDER(a) - EVENT_ORDER(b));
	entries.push({ type: 'meet', key, events: sorted, date: sortKey(sorted[0]) });
}
entries.sort((a, b) => b.date.localeCompare(a.date));

// counts for filter chips — sport count is per-entry (a meet counts once);
// medals + PRs stay per-result so each event's podium/best still tallies.
const catCounts = new Map<string, { label: string; count: number }>();
const medalCounts = [0, 0, 0];
let prCount = 0;
for (const e of entries) {
	if (e.type === 'card') {
		const c = categoryOf(e.r);
		const acc = catCounts.get(c.key) ?? { label: c.label, count: 0 };
		acc.count++; catCounts.set(c.key, acc);
		const p = podiumPlace(e.r); if (p) medalCounts[p - 1]++;
		if (prBadge(e.r)) prCount++;
	} else {
		const acc = catCounts.get('swim_meet') ?? { label: 'Swim Meet', count: 0 };
		acc.count++; catCounts.set('swim_meet', acc);
		for (const ev of e.events) { const p = podiumPlace(ev); if (p) medalCounts[p - 1]++; }
		if (e.events.some(isSwimPr)) prCount++;
	}
}
const catChips = [...catCounts.entries()].sort((a, b) => b[1].count - a[1].count);

// interleave year headers into the date-sorted entries
type Item = { type: 'year'; year: number | null } | CardEntry | MeetEntry;
const items: Item[] = [];
let lastYear: number | null | undefined = undefined;
for (const e of entries) {
	const y = Number(e.date.slice(0, 4)) || null;
	if (y !== lastYear) { items.push({ type: 'year', year: y }); lastYear = y; }
	items.push(e);
}

const age = currentAge(person.birth_date, person.birth_year);
const subtitle = [person.gender, age != null ? `Age ${age}` : null, `${results.length} results`].filter(Boolean).join(' · ');

// data-place for a meet card is the set of its events' podium places (so the
// medal filter reveals a meet that contains, say, a 2nd anywhere inside it).
const meetPlaces = (e: MeetEntry) => [...new Set(e.events.map(podiumPlace).filter((p): p is number => p != null))].join(' ');
---

<Layout title={person.full_name} subtitle={subtitle} avatarUrl={person.avatar_url}>
	<div class="filters">
		<div class="fgroup" style="--g: var(--accent)">
			<span class="anchor"><span class="num">{catChips.length}</span><span class="lab">Sports</span></span>
			{catChips.map(([key, { label, count }]) => (
				<button class="seg" data-f="cat" data-v={key} style={`--c:${CAT_COLOR[key] ?? 'var(--muted)'}`}>
					<span class="ic">{CAT_ICON[key] ?? '🏁'}</span>
					<span class="slabel">{label.split(' ').map((w) => <span class="lw">{w}</span>)}</span>
					<span class="count">{count}</span>
				</button>
			))}
		</div>

		{medalCounts.some((c) => c > 0) && (
			<div class="fgroup" style="--g: var(--gold)">
				<span class="anchor"><span class="num">{medalCounts.reduce((a, b) => a + b, 0)}</span><span class="lab">Podiums</span></span>
				{[1, 2, 3].map((p) => medalCounts[p - 1] > 0 && (
					<button class="seg seg-pod" data-f="place" data-v={String(p)} style={`--c:${MEDAL_COLOR[p - 1]}`}>
						<span class="pod-stack"><span class="ic">{MEDAL[p - 1]}</span><span class="pod-lab">{MEDAL_LABEL[p - 1]}</span></span>
						<span class="count">{medalCounts[p - 1]}</span>
					</button>
				))}
			</div>
		)}

		{prCount > 0 && (
			<label class="fgroup fpr">
				<input type="checkbox" id="pr-only" />
				<span class="pr-box">✓</span>
				<span class="pr-stack"><span class="pr-mark">⭐</span><span class="pr-lab">PRs</span></span>
				<span class="count">{prCount}</span>
			</label>
		)}
	</div>

	{
		items.length === 0 ? (
			<div class="empty">No results recorded yet for {person.full_name}.</div>
		) : (
			<div class="results" id="results">
				{items.map((it) =>
					it.type === 'year' ? (
						<div class="year-header" data-year={String(it.year ?? '')}><span>{it.year ?? '—'}</span></div>
					) : it.type === 'meet' ? (
						(() => {
							const ed = it.events[0].race_edition;
							const dp = dateParts(ed?.date, ed?.year);
							const group = ageGroupOf(it.events.find((e) => e.status === 'finished')?.division ?? it.events[0].division);
							const medals = it.events.filter((e) => podiumPlace(e) != null).length;
							const year = Number(it.date.slice(0, 4)) || ed?.year || '';
							return (
								<article class="mcard" data-cat="swim_meet" data-place={meetPlaces(it)} data-pr={it.events.some(isSwimPr) ? '1' : '0'} data-year={String(year)} style={`--edge:var(--swim); grid-template-rows: repeat(${1 + it.events.length}, auto)`}>
									<div class="mc-date">
										<span class="d-mon">{dp.mon}</span><span class="d-day">{dp.day || dp.year}</span><span class="d-yr">{dp.day ? dp.year : ''}</span>
									</div>
									<div class="mc-head">
										<div class="mc-title">
											<span class="mc-ic">🏊</span>
											{ed?.race ? <a class="mc-name" href={`/races/${ed.race.slug}`}>{ed.race.name}</a> : <span class="mc-name">Swim meet</span>}
										</div>
										<div class="mc-meta">
											<span class="mc-sport">Swim Meet</span>
											{ed?.distance_or_format && <span>· {ed.distance_or_format}</span>}
											{group && <span>· {group}</span>}
											<span>· {it.events.length} {it.events.length === 1 ? 'event' : 'events'}</span>
											{medals > 0 && <span class="mc-medals">· {medals} 🏅</span>}
										</div>
									</div>
									{it.events.map((e, i) => {
										const ev = parseSwimEvent(e.event);
										const place = podiumPlace(e);
										const pr = isSwimPr(e);
										const dq = e.status !== 'finished';
										const row = 2 + i;
										return (
											<Fragment>
												<a class="mc-evname" href={`/swim/${swimEventSlug(e.event)}`} style={`grid-row:${row}; --c:${ev.color}`}>
													<span class="ev-ic">{ev.icon}</span><span class="ev-lbl">{ev.short}</span>
												</a>
												<div class="mc-evtime" style={`grid-row:${row}`}>
													<span class="ev-timewrap">
														<ResultMarks medalTier={place} medalSub={abbrevDivision(ageGroupOf(e.division))} pr={pr && !dq} compact />
														{dq ? (
															<span class="ev-dq">{e.status.toUpperCase()}</span>
														) : (
															<span class={`ev-t${pr ? ' is-pr' : ''}`}>{formatSwimTime(swimCs(e))}</span>
														)}
													</span>
												</div>
												<div class="mc-evplace" style={`grid-row:${row}`}>
													<span class="ev-ord">{e.division_place != null ? ordinal(e.division_place) : '—'}</span>
													{e.division && <span class="ev-heat">{e.division}</span>}
												</div>
											</Fragment>
										);
									})}
								</article>
							);
						})()
					) : (
						(() => {
							const r = it.r;
							const ed = r.race_edition;
							const sport = (ed?.race?.sport ?? 'other') as Sport;
							const cat = categoryOf(r);
							const dp = dateParts(ed?.date, ed?.year);
							const legs = (r.split ?? []).filter((s) => !/^t\d/i.test(s.label));
							const pr = prBadge(r);
							const aw = award(r);
							return (
								<article class={`rcard${aw || pr ? ' has-marks' : ''}`} data-cat={categoryOf(r).key} data-place={String(podiumPlace(r) ?? '')} data-pr={pr ? '1' : '0'} data-year={String(ed?.year ?? '')} style={`--edge:${CAT_COLOR[cat.key] ?? 'var(--muted)'}`}>
									<div class="rc-date">
										<span class="d-mon">{dp.mon}</span><span class="d-day">{dp.day || dp.year}</span><span class="d-yr">{dp.day ? dp.year : ''}</span>
									</div>
									<div class="rc-race">
										<div class="rc-title">
											<span class="rc-cat-ic" style={`color:${CAT_COLOR[cat.key] ?? 'var(--muted)'}`}>{CAT_ICON[cat.key] ?? '🏁'}</span>
											{ed?.race ? <a class="rc-name" href={`/races/${ed.race.slug}`}>{ed.race.name}</a> : <span class="rc-name">Unknown race</span>}
										</div>
										<div class="rc-meta">
											<span class="rc-sport">{sport === 'triathlon' ? cat.label : SPORT_LABELS[sport]}</span>
											{ed?.distance_or_format && (sport !== 'triathlon' || cat.key === 'triathlon') && <span class="rc-dist">· {ed.distance_or_format}</span>}
											{r.event && <span>· {r.event}</span>}
										</div>
									</div>
									<div class="rc-finish">
										<span class="rc-k">Finish</span>
										<span class="rc-timewrap">
											<ResultMarks medalTier={aw ? aw.tier : null} medalSub={aw ? abbrevDivision(aw.sub) : null} pr={!!pr} />
											<span class={`rc-time${pr?.gold ? ' is-pr' : ''}`}>{r.status === 'finished' ? formatTime(r.finish_time_seconds) : r.status.toUpperCase()}</span>
										</span>
									</div>
									<div class="rc-legs">
										{legs.map((s) => (
											<div class="rc-leg">
												<span class="leg-ic" style={`color:${legColor(s.label)}`}>{legIcon(s.label)}</span>
												<span class="leg-t">{formatTime(s.segment_time_seconds)}</span>
												<span class="leg-p">{legPace(s.distance_m, s.segment_time_seconds, s.distance_unit) ?? ''}</span>
											</div>
										))}
									</div>
									<div class="rc-places">
										<div><span class="rc-k">Overall</span><span class="rc-v">{placement(r.overall_place, r.overall_field_size)}</span></div>
										<div><span class="rc-k">Division</span><span class="rc-v">{r.division ? `${r.division}${r.division_place ? ` · ${ordinal(r.division_place)}` : ''}` : '—'}</span></div>
									</div>
								</article>
							);
						})()
					),
				)}
			</div>
		)
	}
</Layout>

<style>
	.filters { display: flex; align-items: stretch; flex-wrap: wrap; gap: 0.7rem; margin-bottom: 1.9rem; }

	/* one rounded box per group: tinted anchor + divided segments */
	.fgroup { display: flex; align-items: stretch; background: var(--surface); border: 1px solid var(--border); border-radius: 14px; box-shadow: var(--shadow); overflow: hidden; }

	.anchor { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; line-height: 0.82; padding: 0.55rem 1rem; background: color-mix(in srgb, var(--g, var(--accent)) 15%, var(--surface)); border-right: 1px solid var(--border); }
	.anchor .num { font-family: var(--font-display); font-weight: 400; font-size: 2.3rem; letter-spacing: 0.02em; color: var(--g, var(--accent)); }
	.anchor .lab { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-top: 0.32rem; }

	/* each breakdown segment, divided from its neighbor, highlights when active */
	.seg { display: flex; align-items: center; gap: 0.45rem; padding: 0.4rem 0.75rem; background: transparent; border: none; border-right: 1px solid var(--border); font: inherit; cursor: pointer; color: var(--muted); transition: background 0.12s, color 0.12s; white-space: nowrap; }
	.seg:last-child { border-right: none; }
	.seg .ic { font-size: 1.25rem; line-height: 1; }
	.seg .slabel { display: inline-flex; flex-direction: column; align-items: flex-start; line-height: 1.02; font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.06em; text-transform: uppercase; }
	.seg .lw { display: block; }
	.seg .count { font-family: var(--font-display); font-weight: 400; font-size: 1.5rem; line-height: 0.9; color: var(--c, var(--accent)); }
	.seg:hover { background: color-mix(in srgb, var(--c, var(--accent)) 12%, transparent); color: var(--text); }
	.seg.active { background: color-mix(in srgb, var(--c, var(--accent)) 24%, transparent); color: var(--text); }
	.seg.active .slabel { color: var(--text); }

	/* podium segments stack the medal icon over its rank */
	.seg-pod .pod-stack { display: inline-flex; flex-direction: column; align-items: center; gap: 0.12rem; }
	.seg-pod .ic { font-size: 1.2rem; }
	.seg-pod .pod-lab { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.06em; text-transform: uppercase; }

	/* "PRs only" checkbox chiclet at the end of the filter row */
	.fpr { cursor: pointer; align-items: center; gap: 0.55rem; padding: 0.4rem 0.95rem; user-select: none; }
	.fpr input { position: absolute; opacity: 0; pointer-events: none; }
	.pr-box { display: inline-flex; align-items: center; justify-content: center; width: 1.15rem; height: 1.15rem; border: 1.5px solid var(--border); border-radius: 6px; color: transparent; font-size: 0.8rem; font-weight: 700; transition: background 0.12s, border-color 0.12s, color 0.12s; }
	.fpr:hover .pr-box { border-color: var(--gold); }
	.fpr input:checked ~ .pr-box { background: var(--gold); border-color: var(--gold); color: #3a2a00; }
	.fpr .pr-stack { display: inline-flex; flex-direction: column; align-items: center; gap: 0.12rem; line-height: 1; }
	.fpr .pr-mark { font-size: 1.2rem; }
	.fpr .pr-lab { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
	.fpr .count { font-family: var(--font-display); font-weight: 400; font-size: 1.5rem; line-height: 0.9; color: var(--gold); }
	.fpr:has(input:checked) { border-color: var(--gold); background: color-mix(in srgb, var(--gold) 14%, var(--surface)); }

	/* one grid for all rows so finish times line up across every card */
	.results { display: grid; grid-template-columns: 86px minmax(150px, 1fr) max-content max-content max-content; row-gap: 0.7rem; }
	.year-header { grid-column: 1 / -1; display: flex; align-items: center; gap: 1rem; margin: 1.4rem 0 0.2rem; }
	.year-header:first-child { margin-top: 0; }
	.year-header span { font-family: var(--font-display); font-weight: 400; font-size: 2rem; letter-spacing: 0.04em; color: var(--accent); }
	.year-header::after { content: ''; flex: 1; height: 1px; background: var(--border); }

	.rcard {
		grid-column: 1 / -1; display: grid; grid-template-columns: subgrid; align-items: stretch;
		background: linear-gradient(180deg, var(--surface-2), var(--surface) 90px);
		border: 1px solid var(--border); border-radius: 14px; box-shadow: var(--shadow); overflow: hidden;
	}
