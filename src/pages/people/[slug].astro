---
import Layout from '../../layouts/Layout.astro';
import ResultRow from '../../components/ResultRow.astro';
import MeetCard from '../../components/MeetCard.astro';
import UpcomingRow from '../../components/UpcomingRow.astro';
import { getPersonBySlug, getUpcomingRaces, type UpcomingRace } from '../../lib/queries';
import { categoryOf, catColor, catIcon } from '../../lib/categories';
import { MEDAL_EMOJI, MEDAL_NAME, MEDAL_COLOR } from '../../lib/medals';
import { currentAge } from '../../lib/format';
import { buildEntries, buildPrContext, podiumPlace, award, type Entry } from '../../lib/feed';

const { slug } = Astro.params;
const data = slug ? await getPersonBySlug(slug) : null;
if (!data) return new Response('Person not found', { status: 404 });
const { person, results } = data;

// DEV-19: this person's upcoming races — the upcoming editions in the sport(s) they
// compete in (Sierra & Aurora swim → the Glade Dolphins meets show on their pages).
const mySports = new Set(results.map((r) => r.race_edition?.race?.sport).filter(Boolean));
const personUpcoming = (await getUpcomingRaces()).filter((u) => u.race && mySports.has(u.race.sport));

const prCtx = buildPrContext(results);
const entries = buildEntries(results);

// filter chip counts — sport count is per-entry (a meet counts once);
// medals + PRs stay per-result so each event's podium/best still tallies.
const catCounts = new Map<string, { label: string; count: number }>();
const medalCounts = [0, 0, 0];
let prCount = 0;
for (const e of entries) {
	if (e.type === 'card') {
		const c = categoryOf(e.r);
		const acc = catCounts.get(c.key) ?? { label: c.label, count: 0 };
		acc.count++; catCounts.set(c.key, acc);
		const p = podiumPlace(e.r); if (p) medalCounts[p - 1]++;
		if (prCtx.prBadge(e.r)) prCount++;
	} else {
		const acc = catCounts.get('swim_meet') ?? { label: 'Swim Meet', count: 0 };
		acc.count++; catCounts.set('swim_meet', acc);
		for (const ev of e.events) { const p = podiumPlace(ev); if (p) medalCounts[p - 1]++; }
		if (e.events.some(prCtx.isSwimPr)) prCount++;
	}
}
const catChips = [...catCounts.entries()].sort((a, b) => b[1].count - a[1].count);

// Upcoming races lead the feed as rows under their own year (DEV-19) — future dates, so
// prepending them date-descending keeps the whole feed chronological (every upcoming date
// is after every past result), and the 2026 Glade meets sit at the top of the 2026 group.
type UpcomingItem = { type: 'upcoming'; date: string; race: UpcomingRace };
const upcomingItems: UpcomingItem[] = [...personUpcoming]
	.reverse()
	.map((u) => ({ type: 'upcoming', date: u.date ?? `${u.year}-12-31`, race: u }));

// interleave year headers into the date-sorted feed (upcoming first, then results)
type Item = { type: 'year'; year: number | null } | UpcomingItem | Entry;
const items: Item[] = [];
let lastYear: number | null | undefined = undefined;
for (const e of [...upcomingItems, ...entries]) {
	const y = Number(e.date.slice(0, 4)) || null;
	if (y !== lastYear) { items.push({ type: 'year', year: y }); lastYear = y; }
	items.push(e);
}
// the #upcoming deep-link (Home → /people/[slug]#upcoming) scrolls to the first upcoming row
const firstUpcoming = items.find((it): it is UpcomingItem => it.type === 'upcoming');

const age = currentAge(person.birth_date, person.birth_year);
const subtitle = [person.gender, age != null ? `Age ${age}` : null, `${results.length} results`].filter(Boolean).join(' · ');
---

<Layout title={person.full_name} subtitle={subtitle} avatarUrl={person.avatar_url} crumbs={[{ label: 'All Races', href: '/races' }]}>
	<div class="filters">
		<div class="fgroup" style="--g: var(--accent)">
			<span class="anchor"><span class="num">{catChips.length}</span><span class="lab">Sports</span></span>
			{catChips.map(([key, { label, count }]) => (
				<button class="seg" data-f="cat" data-v={key} style={`--c:${catColor(key)}`}>
					<span class="ic">{catIcon(key)}</span>
					<span class="slabel">{label.split(' ').map((w) => <span class="lw">{w}</span>)}</span>
					<span class="count">{count}</span>
				</button>
			))}
		</div>

		{medalCounts.some((c) => c > 0) && (
			<div class="fgroup" style="--g: var(--gold)">
				<span class="anchor"><span class="num">{medalCounts.reduce((a, b) => a + b, 0)}</span><span class="lab">Podiums</span></span>
				{[1, 2, 3].map((p) => medalCounts[p - 1] > 0 && (
					<button class="seg seg-pod" data-f="place" data-v={String(p)} style={`--c:${MEDAL_COLOR[p - 1]}`}>
						<span class="pod-stack"><span class="ic">{MEDAL_EMOJI[p - 1]}</span><span class="pod-lab">{MEDAL_NAME[p - 1]}</span></span>
						<span class="count">{medalCounts[p - 1]}</span>
					</button>
				))}
			</div>
		)}

		{prCount > 0 && (
			<label class="fgroup fpr">
				<input type="checkbox" id="pr-only" />
				<span class="pr-box">✓</span>
				<span class="pr-stack"><span class="pr-mark">⭐</span><span class="pr-lab">PRs</span></span>
				<span class="count">{prCount}</span>
			</label>
		)}
	</div>

	{
		items.length === 0 ? (
			<div class="empty">No results recorded yet for {person.full_name}.</div>
		) : (
			<div class="results" id="results">
				{items.map((it) =>
					it.type === 'year' ? (
						<div class="year-header" data-year={String(it.year ?? '')}><span>{it.year ?? '—'}</span></div>
					) : it.type === 'upcoming' ? (
						<UpcomingRow race={it.race} anchorId={it === firstUpcoming ? 'upcoming' : null} />
					) : it.type === 'meet' ? (
						<MeetCard entry={it} prCtx={prCtx} />
					) : (
						<ResultRow r={it.r} pr={prCtx.prBadge(it.r)} aw={award(it.r)} />
					),
				)}
			</div>
		)
	}
</Layout>

<style>
	.filters { display: flex; align-items: stretch; flex-wrap: wrap; gap: 0.7rem; margin-bottom: 1.9rem; }

	/* one rounded box per group: tinted anchor + divided segments */
	.fgroup { display: flex; align-items: stretch; background: var(--surface); border: 1px solid var(--border); border-radius: 14px; box-shadow: var(--shadow); overflow: hidden; }

	.anchor { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; line-height: 0.82; padding: 0.55rem 1rem; background: color-mix(in srgb, var(--g, var(--accent)) 15%, var(--surface)); border-right: 1px solid var(--border); }
	.anchor .num { font-family: var(--font-display); font-weight: 400; font-size: 2.3rem; letter-spacing: 0.02em; color: var(--g, var(--accent)); }
	.anchor .lab { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-top: 0.32rem; }

	/* each breakdown segment, divided from its neighbor, highlights when active */
	.seg { display: flex; align-items: center; gap: 0.45rem; padding: 0.4rem 0.75rem; background: transparent; border: none; border-right: 1px solid var(--border); font: inherit; cursor: pointer; color: var(--muted); transition: background 0.12s, color 0.12s; white-space: nowrap; }
	.seg:last-child { border-right: none; }
	.seg .ic { font-size: 1.25rem; line-height: 1; }
	.seg .slabel { display: inline-flex; flex-direction: column; align-items: flex-start; line-height: 1.02; font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.06em; text-transform: uppercase; }
	.seg .lw { display: block; }
	.seg .count { font-family: var(--font-display); font-weight: 400; font-size: 1.5rem; line-height: 0.9; color: var(--c, var(--accent)); }
	.seg:hover { background: color-mix(in srgb, var(--c, var(--accent)) 12%, transparent); color: var(--text); }
	.seg.active { background: color-mix(in srgb, var(--c, var(--accent)) 24%, transparent); color: var(--text); }
	.seg.active .slabel { color: var(--text); }

	/* podium segments stack the medal icon over its rank */
	.seg-pod .pod-stack { display: inline-flex; flex-direction: column; align-items: center; gap: 0.12rem; }
	.seg-pod .ic { font-size: 1.2rem; }
	.seg-pod .pod-lab { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.06em; text-transform: uppercase; }

	/* "PRs only" checkbox chiclet at the end of the filter row */
	.fpr { cursor: pointer; align-items: center; gap: 0.55rem; padding: 0.4rem 0.95rem; user-select: none; }
	.fpr input { position: absolute; opacity: 0; pointer-events: none; }
	.pr-box { display: inline-flex; align-items: center; justify-content: center; width: 1.15rem; height: 1.15rem; border: 1.5px solid var(--border); border-radius: 6px; color: transparent; font-size: 0.8rem; font-weight: 700; transition: background 0.12s, border-color 0.12s, color 0.12s; }
	.fpr:hover .pr-box { border-color: var(--gold); }
	.fpr input:checked ~ .pr-box { background: var(--gold); border-color: var(--gold); color: #3a2a00; }
	.fpr .pr-stack { display: inline-flex; flex-direction: column; align-items: center; gap: 0.12rem; line-height: 1; }
	.fpr .pr-mark { font-size: 1.2rem; }
	.fpr .pr-lab { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
	.fpr .count { font-family: var(--font-display); font-weight: 400; font-size: 1.5rem; line-height: 0.9; color: var(--gold); }
	.fpr:has(input:checked) { border-color: var(--gold); background: color-mix(in srgb, var(--gold) 14%, var(--surface)); }

	/* .results + .year-header live in Layout.astro */
</style>

<script>
	// includes upcoming rows (.ucard): they carry data-cat/data-year but no place/PR, so
	// a sport filter keeps the matching upcoming races and the place/PR filters drop them.
	const cards = [...document.querySelectorAll<HTMLElement>('.rcard, .mcard, .ucard')];
	const headers = [...document.querySelectorAll<HTMLElement>('.year-header')];
	const chips = [...document.querySelectorAll<HTMLElement>('[data-f]')];
	const prOnlyEl = document.querySelector<HTMLInputElement>('#pr-only');
	let f = 'all';
	let v = '';

	function apply() {
		const prOnly = !!prOnlyEl?.checked;
		for (const c of cards) {
			const places = (c.dataset.place || '').split(' ').filter(Boolean);
			const matchF = f === 'all' || (f === 'cat' && c.dataset.cat === v) || (f === 'place' && places.includes(v));
			const ok = matchF && (!prOnly || c.dataset.pr === '1');
			c.style.display = ok ? '' : 'none';
		}
		for (const h of headers) {
			const y = h.dataset.year;
			h.style.display = cards.some((c) => c.dataset.year === y && c.style.display !== 'none') ? '' : 'none';
		}
	}
	prOnlyEl?.addEventListener('change', apply);
	chips.forEach((ch) =>
		ch.addEventListener('click', () => {
			if (ch.classList.contains('active')) {
				// clicking the active filter clears it back to all
				f = 'all';
				v = '';
				ch.classList.remove('active');
			} else {
				f = ch.dataset.f || 'all';
				v = ch.dataset.v || '';
				chips.forEach((x) => x.classList.toggle('active', x === ch));
			}
			apply();
		}),
	);
</script>
