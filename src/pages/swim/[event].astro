---
import Layout from '../../layouts/Layout.astro';
import ResultMarks from '../../components/ResultMarks.astro';
import ResultPlaces from '../../components/ResultPlaces.astro';
import RaceTitle from '../../components/RaceTitle.astro';
import PersonChip from '../../components/PersonChip.astro';
import PrTime from '../../components/PrTime.astro';
import DateRail from '../../components/DateRail.astro';
import CategoryTag from '../../components/CategoryTag.astro';
import { getAllFamilyResults, type FeedResult } from '../../lib/queries';
import { formatSwimTime, formatSwimDelta, deltaDirection, parseSwimEvent, swimEventSlug, isPodium, swimDivision } from '../../lib/format';

const { event } = Astro.params;
const who = Astro.url.searchParams.get('who');
const all = await getAllFamilyResults();
const eventRows = all.filter((r) => (r.race_edition?.race?.sport ?? '') === 'swim_meet' && swimEventSlug(r.event) === event);
if (eventRows.length === 0) return new Response('Event not found', { status: 404 });

const ev = parseSwimEvent(eventRows[0].event);
const title = eventRows[0].event ?? ev.short; // canonical "50m Backstroke"

const swimCs = (r: FeedResult) => r.finish_time_cs ?? (r.finish_time_seconds != null ? r.finish_time_seconds * 100 : null);
const sortKey = (r: FeedResult) => r.race_edition?.date ?? `${r.race_edition?.year ?? 0}-00-00`;

// Per-swimmer discipline page (DEV-13): scoped to the ONE swimmer you came from
// (?who=<slug>, set on every event link). With no ?who — a bare/shared URL — default to
// the oldest family swimmer for this event, so the page is always a single swimmer.
const wanted = who ?? [...eventRows]
	.filter((r) => r.person?.slug)
	.sort((a, b) => (a.person!.birth_year ?? 0) - (b.person!.birth_year ?? 0))[0]?.person?.slug ?? null;
const matching = wanted ? eventRows.filter((r) => r.person?.slug === wanted) : [];
if (matching.length === 0) return new Response('Event not found for this swimmer', { status: 404 });
const person = matching[0].person!;

// This swimmer's progression in this event. Each occurrence shows the delta vs the
// previous swim; the all-time best is starred (PR) and tinted gold.
interface Occ { r: FeedResult; cs: number | null; deltaCs: number | null; isBest: boolean }
const chrono = [...matching].sort((a, b) => sortKey(a).localeCompare(sortKey(b))); // oldest first
const finishedCs = chrono.filter((r) => r.status === 'finished').map(swimCs).filter((c): c is number => c != null);
const bestCs = finishedCs.length ? Math.min(...finishedCs) : null;
let prevCs: number | null = null;
const occ: Occ[] = chrono.map((r) => {
	const cs = r.status === 'finished' ? swimCs(r) : null;
	const deltaCs = cs != null && prevCs != null ? cs - prevCs : null;
	if (cs != null) prevCs = cs;
	return { r, cs, deltaCs, isBest: cs != null && cs === bestCs };
}).reverse(); // newest first for display
const bestRow = bestCs != null ? chrono.find((r) => swimCs(r) === bestCs) : null;
const bestYear = bestRow?.race_edition?.year ?? null;

// Group the (newest-first) occurrences into year sections, newest year first (DEV-13).
interface YearGroup { year: number | null; items: Occ[] }
const byYear: YearGroup[] = [];
for (const o of occ) {
	const y = o.r.race_edition?.year ?? (Number((o.r.race_edition?.date ?? '').slice(0, 4)) || null);
	let g = byYear[byYear.length - 1];
	if (!g || g.year !== y) { g = { year: y, items: [] }; byYear.push(g); }
	g.items.push(o);
}
---

<Layout
	title={title}
	crumbs={[{ label: 'All Races', href: '/races' }, { label: person.full_name, href: person.slug ? `/people/${person.slug}` : '/races' }]}
>
	<div class="sub-tag" slot="subtitle"><CategoryTag catKey="swim_meet" label="Swim Meet" icon /></div>

	<header class="disc-head">
		<PersonChip person={person} avatar={38} nameRem={1.05} />
		{bestCs != null && <PrTime time={formatSwimTime(bestCs)} caption={bestYear ? String(bestYear) : null} />}
	</header>

	{/* One swimmer's progression, grouped by year (newest first), in the SAME shared
	   `.results` grid every feed row uses — so the meet name, finish time, and standing
	   land in the same columns as a tri/run row (time mid-row, not pinned to the edge).
	   The per-swim delta fills the "legs" slot between the time and the standing. */}
	<div class="results">
		{byYear.map((grp) => (
			<Fragment>
				<div class="year-header"><span>{grp.year ?? '—'}</span></div>
				{grp.items.map((o) => {
					const r = o.r;
					const ed = r.race_edition;
					const place = r.division_place;
					const podium = isPodium(place) ? place : null;
					const dq = r.status !== 'finished';
					const pr = o.isBest && !dq;
					const dir = o.deltaCs != null ? deltaDirection(o.deltaCs, 0) : 'same';
					return (
						<article class:list={['ocard', 'feed-card', { 'has-marks': podium || pr }]} style="--edge: var(--swim)">
							<DateRail date={ed?.date} year={ed?.year} />
							<div class="oc-meet">
								<RaceTitle catKey="swim_meet" name={ed?.race?.name ?? 'Swim meet'} href={ed?.race ? `/races/${ed.race.slug}` : null} nameRem={1.25} />
							</div>
							<div class="oc-finish">
								<span class="sr-only">Finish </span>
								<span class="oc-timewrap">
									<ResultMarks medalTier={podium} medalSub={swimDivision(r.division)} pr={pr} compact />
									{dq ? (
										<span class="oc-t is-dq">{r.status.toUpperCase()}</span>
									) : (
										<span class:list={['oc-t', { 'is-pr': o.isBest }]}>{formatSwimTime(o.cs)}</span>
									)}
								</span>
							</div>
							<div class="oc-delta">
								{o.deltaCs != null && o.deltaCs !== 0 && <span class={`delta ${dir}`}>{formatSwimDelta(o.deltaCs, 0)}</span>}
								{o.deltaCs === 0 && <span class="delta same">±0.00</span>}
							</div>
							<div class="oc-places">
								<ResultPlaces overallPlace={r.overall_place} overallFieldSize={r.overall_field_size} division={r.division} divisionPlace={r.division_place} />
							</div>
						</article>
					);
				})}
			</Fragment>
		))}
	</div>
</Layout>

<style>
	.sub-tag { margin-top: 0.5rem; }

	/* Swimmer identity for this discipline page — the shared PersonChip (avatar + name),
	   with the all-time best (PrTime) beside it. */
	.disc-head { display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1.4rem; }

	/* Rows live in the shared `.results` subgrid (Layout.astro): date rail · meet name ·
	   finish · [delta] · standing — column-for-column with ResultRow / MeetCard, so a swim
	   discipline row reads identically to every other row on the site. */
	.oc-meet { display: flex; flex-direction: column; justify-content: center; padding: 0.85rem 1.1rem; min-width: 0; }
	.ocard.has-marks .oc-meet { padding-right: 76px; }

	.oc-finish { position: relative; display: flex; flex-direction: column; justify-content: center; padding: 0.85rem 1.1rem; }
	.oc-timewrap { position: relative; width: max-content; }
	.oc-t { font-family: var(--font-display); font-weight: 400; font-size: var(--fs-time-lg); line-height: 0.9; letter-spacing: var(--ls-tight); white-space: nowrap; }
	.oc-t.is-pr { color: var(--gold); }
	.oc-t.is-dq { color: var(--slower); }

	.oc-delta { display: flex; align-items: center; padding: 0.85rem 1.1rem; }
	.delta { font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700; white-space: nowrap; }
	.delta.faster { color: var(--faster); }
	.delta.slower { color: var(--slower); }
	.delta.same { color: var(--faint); }

	.oc-places { display: flex; flex-direction: column; justify-content: center; padding: 0.85rem 1.2rem 0.85rem 1.1rem; }
</style>
