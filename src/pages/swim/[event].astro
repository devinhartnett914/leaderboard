---
import Layout from '../../layouts/Layout.astro';
import ResultMarks from '../../components/ResultMarks.astro';
import ResultPlaces from '../../components/ResultPlaces.astro';
import FinishTime from '../../components/FinishTime.astro';
import RaceTitle from '../../components/RaceTitle.astro';
import StatChips from '../../components/StatChips.astro';
import DateRail from '../../components/DateRail.astro';
import CategoryTag from '../../components/CategoryTag.astro';
import { getAllFamilyResults, type FeedResult } from '../../lib/queries';
import { formatSwimTime, formatSwimDelta, deltaDirection, parseSwimEvent, swimEventSlug, isPodium, swimDivision } from '../../lib/format';

const { event } = Astro.params;
const who = Astro.url.searchParams.get('who');
const all = await getAllFamilyResults();
const eventRows = all.filter((r) => (r.race_edition?.race?.sport ?? '') === 'swim_meet' && swimEventSlug(r.event) === event);
if (eventRows.length === 0) return new Response('Event not found', { status: 404 });

const ev = parseSwimEvent(eventRows[0].event);
const eventLabel = eventRows[0].event ?? ev.short; // canonical "50m Backstroke" (stroke + distance)

const swimCs = (r: FeedResult) => r.finish_time_cs ?? (r.finish_time_seconds != null ? r.finish_time_seconds * 100 : null);
const sortKey = (r: FeedResult) => r.race_edition?.date ?? `${r.race_edition?.year ?? 0}-00-00`;

// Per-swimmer discipline page (DEV-13): scoped to the ONE swimmer you came from
// (?who=<slug>, set on every event link). With no ?who — a bare/shared URL — default to
// the oldest family swimmer for this event, so the page is always a single swimmer.
const wanted = who ?? [...eventRows]
	.filter((r) => r.person?.slug)
	.sort((a, b) => (a.person!.birth_year ?? 0) - (b.person!.birth_year ?? 0))[0]?.person?.slug ?? null;
const matching = wanted ? eventRows.filter((r) => r.person?.slug === wanted) : [];
if (matching.length === 0) return new Response('Event not found for this swimmer', { status: 404 });
const person = matching[0].person!;

// This swimmer's progression in this event. Each occurrence shows the delta vs the
// previous swim; the all-time best is starred (PR) and tinted gold.
interface Occ { r: FeedResult; cs: number | null; deltaCs: number | null; isBest: boolean }
const chrono = [...matching].sort((a, b) => sortKey(a).localeCompare(sortKey(b))); // oldest first
const finishedCs = chrono.filter((r) => r.status === 'finished').map(swimCs).filter((c): c is number => c != null);
const bestCs = finishedCs.length ? Math.min(...finishedCs) : null;
let prevCs: number | null = null;
const occ: Occ[] = chrono.map((r) => {
	const cs = r.status === 'finished' ? swimCs(r) : null;
	const deltaCs = cs != null && prevCs != null ? cs - prevCs : null;
	if (cs != null) prevCs = cs;
	return { r, cs, deltaCs, isBest: cs != null && cs === bestCs };
}).reverse(); // newest first for display
const bestRow = bestCs != null ? chrono.find((r) => swimCs(r) === bestCs) : null;
const bestYear = bestRow?.race_edition?.year ?? null;

// Stat chips (DEV-13): this swimmer's podium medals in this event + their PR. Medals are
// counted off the same division place the rows badge, so the tally matches the marks below.
const medalCounts = [0, 0, 0];
for (const o of occ) {
	const place = o.r.division_place;
	if (o.r.status === 'finished' && isPodium(place) && place! >= 1) medalCounts[place! - 1]++;
}
const prStat = bestCs != null ? { time: formatSwimTime(bestCs), year: bestYear ? String(bestYear) : null } : null;

// Group the (newest-first) occurrences into year sections, newest year first (DEV-13).
interface YearGroup { year: number | null; items: Occ[] }
const byYear: YearGroup[] = [];
for (const o of occ) {
	const y = o.r.race_edition?.year ?? (Number((o.r.race_edition?.date ?? '').slice(0, 4)) || null);
	let g = byYear[byYear.length - 1];
	if (!g || g.year !== y) { g = { year: y, items: [] }; byYear.push(g); }
	g.items.push(o);
}
---

<Layout
	title={person.full_name}
	avatarUrl={person.avatar_url}
	crumbs={[{ label: 'All Races', href: '/races' }]}
>
	{/* Header mirrors the person page (DEV-13): avatar + NAME, with the stroke + distance
	   as the swim-tinted sub-tag underneath. The person breadcrumb is gone (the name is
	   now the H1 — it would be duplicative). */}
	<div class="sub-tag" slot="subtitle"><CategoryTag catKey="swim_meet" label={eventLabel} icon /></div>

	{/* Medals + PR for this swimmer in this event, in the person-page filter-chip style. */}
	<StatChips medalCounts={medalCounts} pr={prStat} />

	{/* One swimmer's progression, grouped by year (newest first). Swim rows carry no
	   leg-splits to fill the middle the way a tri/run row does, so instead of the shared
	   feed grid (which would leave a big empty gap and clump the data on the right) the
	   row uses its OWN proportional grid — date · meet · time · delta · standing spread
	   evenly across the width. */}
	<div class="occ-list">
		{byYear.map((grp) => (
			<Fragment>
				<div class="year-header"><span>{grp.year ?? '—'}</span></div>
				{grp.items.map((o) => {
					const r = o.r;
					const ed = r.race_edition;
					const place = r.division_place;
					const podium = isPodium(place) ? place : null;
					const dq = r.status !== 'finished';
					const pr = o.isBest && !dq;
					const dir = o.deltaCs != null ? deltaDirection(o.deltaCs, 0) : 'same';
					return (
						<article class:list={['ocard', { 'is-pr': o.isBest, 'is-marked': !!podium || pr }]} style="--edge: var(--swim)">
							<DateRail date={ed?.date} year={ed?.year} />
							<div class="oc-meet">
								<RaceTitle catKey="swim_meet" name={ed?.race?.name ?? 'Swim meet'} href={ed?.race ? `/races/${ed.race.slug}` : null} />
							</div>
							<div class="oc-time">
								<span class="oc-timewrap">
									<ResultMarks medalTier={podium} medalSub={swimDivision(r.division)} pr={pr} compact />
									<FinishTime time={dq ? '' : formatSwimTime(o.cs)} status={r.status} pr={o.isBest && !dq} />
								</span>
							</div>
							<div class="oc-delta">
								{o.deltaCs != null && o.deltaCs !== 0 && <span class={`delta ${dir}`}>{formatSwimDelta(o.deltaCs, 0)}</span>}
								{o.deltaCs === 0 && <span class="delta same">±0.00</span>}
							</div>
							<div class="oc-place">
								<ResultPlaces overallPlace={r.overall_place} overallFieldSize={r.overall_field_size} division={r.division} divisionPlace={r.division_place} />
							</div>
						</article>
					);
				})}
			</Fragment>
		))}
	</div>
</Layout>

<style>
	.sub-tag { margin-top: 0.5rem; }

	/* Own proportional grid (not the shared 5-col feed grid): the flexible space is spread
	   across ALL columns so the data distributes evenly instead of clumping on the right.
	   date · meet · time · delta · standing. */
	.occ-list { display: grid; grid-template-columns: 86px minmax(0, 2.3fr) minmax(0, 1fr) minmax(0, 0.85fr) minmax(0, 1.2fr); row-gap: 0.7rem; }
	.ocard {
		grid-column: 1 / -1; display: grid; grid-template-columns: subgrid; align-items: stretch;
		background: linear-gradient(180deg, var(--surface-2), var(--surface) 90px);
		border: 1px solid var(--border); border-left: 3px solid var(--edge);
		border-radius: 14px; box-shadow: var(--shadow); overflow: hidden;
	}
	.ocard.is-pr { border-color: color-mix(in srgb, var(--gold) 45%, var(--border)); }

	.oc-meet { display: flex; align-items: center; padding: 0.85rem 1.1rem; min-width: 0; }
	/* marked rows reserve room so the medal/PR (which hangs to the left of the time)
	   doesn't run under the meet name — same idea as the feed's .has-marks padding. */
	.ocard.is-marked .oc-meet { padding-right: 3.4rem; }

	/* Times line up across rows the same way the feed does: the time sits at a fixed left
	   edge and the medal/PR marks hang to its left (absolute), so a row WITH a medal/PR no
	   longer shoves the time over. Finish time renders through the shared <FinishTime/>. */
	.oc-time { display: flex; align-items: center; padding: 0.85rem 0.5rem; min-width: 0; }
	.oc-timewrap { position: relative; width: max-content; }

	.oc-delta { display: flex; align-items: center; padding: 0.85rem 0.5rem; }
	/* delta reads at the same size as the place/division (ResultPlaces' .st-main = --fs-value),
	   so the progression number sits level with the standing instead of looking shrunken. */
	.delta { font-family: var(--font-mono); font-size: var(--fs-value); font-weight: 700; white-space: nowrap; }
	.delta.faster { color: var(--faster); }
	.delta.slower { color: var(--slower); }
	.delta.same { color: var(--faint); }

	.oc-place { display: flex; align-items: center; padding: 0.85rem 1.1rem; min-width: 0; }
</style>
