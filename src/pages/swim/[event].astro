---
import Layout from '../../layouts/Layout.astro';
import ResultMarks from '../../components/ResultMarks.astro';
import PrTime from '../../components/PrTime.astro';
import DateRail from '../../components/DateRail.astro';
import CategoryTag from '../../components/CategoryTag.astro';
import { getAllFamilyResults, type FeedResult } from '../../lib/queries';
import { formatSwimTime, formatSwimDelta, deltaDirection, parseSwimEvent, swimEventSlug, divisionRank, isPodium, swimDivision } from '../../lib/format';

const { event } = Astro.params;
const who = Astro.url.searchParams.get('who');
const all = await getAllFamilyResults();
const eventRows = all.filter((r) => (r.race_edition?.race?.sport ?? '') === 'swim_meet' && swimEventSlug(r.event) === event);
if (eventRows.length === 0) return new Response('Event not found', { status: 404 });

const ev = parseSwimEvent(eventRows[0].event);
const title = eventRows[0].event ?? ev.short; // canonical "50m Backstroke"

const swimCs = (r: FeedResult) => r.finish_time_cs ?? (r.finish_time_seconds != null ? r.finish_time_seconds * 100 : null);
const sortKey = (r: FeedResult) => r.race_edition?.date ?? `${r.race_edition?.year ?? 0}-00-00`;

// Per-swimmer discipline page (DEV-13): scoped to the ONE swimmer you came from
// (?who=<slug>, set on every event link). With no ?who — a bare/shared URL — default to
// the oldest family swimmer for this event, so the page is always a single swimmer.
const wanted = who ?? [...eventRows]
	.filter((r) => r.person?.slug)
	.sort((a, b) => (a.person!.birth_year ?? 0) - (b.person!.birth_year ?? 0))[0]?.person?.slug ?? null;
const matching = wanted ? eventRows.filter((r) => r.person?.slug === wanted) : [];
if (matching.length === 0) return new Response('Event not found for this swimmer', { status: 404 });
const person = matching[0].person!;

// This swimmer's progression in this event. Each occurrence shows the delta vs the
// previous swim; the all-time best is starred (PR) and tinted gold.
interface Occ { r: FeedResult; cs: number | null; deltaCs: number | null; isBest: boolean }
const chrono = [...matching].sort((a, b) => sortKey(a).localeCompare(sortKey(b))); // oldest first
const finishedCs = chrono.filter((r) => r.status === 'finished').map(swimCs).filter((c): c is number => c != null);
const bestCs = finishedCs.length ? Math.min(...finishedCs) : null;
let prevCs: number | null = null;
const occ: Occ[] = chrono.map((r) => {
	const cs = r.status === 'finished' ? swimCs(r) : null;
	const deltaCs = cs != null && prevCs != null ? cs - prevCs : null;
	if (cs != null) prevCs = cs;
	return { r, cs, deltaCs, isBest: cs != null && cs === bestCs };
}).reverse(); // newest first for display
const bestRow = bestCs != null ? chrono.find((r) => swimCs(r) === bestCs) : null;
const bestYear = bestRow?.race_edition?.year ?? null;

// Group the (newest-first) occurrences into year sections, newest year first (DEV-13).
interface YearGroup { year: number | null; items: Occ[] }
const byYear: YearGroup[] = [];
for (const o of occ) {
	const y = o.r.race_edition?.year ?? (Number((o.r.race_edition?.date ?? '').slice(0, 4)) || null);
	let g = byYear[byYear.length - 1];
	if (!g || g.year !== y) { g = { year: y, items: [] }; byYear.push(g); }
	g.items.push(o);
}
---

<Layout
	title={title}
	crumbs={[{ label: 'All Races', href: '/races' }, { label: person.full_name, href: person.slug ? `/people/${person.slug}` : '/races' }]}
>
	<div class="sub-tag" slot="subtitle"><CategoryTag catKey="swim_meet" label="Swim Meet" icon /></div>

	<section class="track">
		<div class="track-head">
			<h2>{person.slug ? <a href={`/people/${person.slug}`}>{person.full_name}</a> : person.full_name}</h2>
			{bestCs != null && <PrTime time={formatSwimTime(bestCs)} caption={bestYear ? String(bestYear) : null} />}
			<span class="track-count">{occ.length} {occ.length === 1 ? 'swim' : 'swims'}</span>
		</div>

		<div class="occ-list">
			{byYear.map((grp) => (
				<Fragment>
					<div class="year-header"><span>{grp.year ?? '—'}</span></div>
					{grp.items.map((o) => {
						const r = o.r;
						const ed = r.race_edition;
						const place = r.division_place;
						const podium = isPodium(place);
						const dq = r.status !== 'finished';
						const dir = o.deltaCs != null ? deltaDirection(o.deltaCs, 0) : 'same';
						return (
							<article class={`occ${o.isBest ? ' is-best' : ''}`} style={`--c:${ev.color}`}>
								<DateRail date={ed?.date} year={ed?.year} color={ev.color} />
								<div class="occ-meet">
									{ed?.race ? <a class="occ-name" href={`/races/${ed.race.slug}`}>{ed.race.name}</a> : <span class="occ-name">Swim meet</span>}
								</div>
								<div class="occ-time">
									<span class="occ-timewrap">
										<ResultMarks medalTier={podium ? place : null} medalSub={swimDivision(r.division)} pr={o.isBest && !dq} compact />
										{dq ? (
											<span class="occ-dq">{r.status.toUpperCase()}</span>
										) : (
											<span class={`occ-t${o.isBest ? ' is-best' : ''}`}>{formatSwimTime(o.cs)}</span>
										)}
									</span>
									{o.deltaCs != null && o.deltaCs !== 0 && <span class={`delta ${dir}`}>{formatSwimDelta(o.deltaCs, 0)}</span>}
									{o.deltaCs === 0 && <span class="delta same">±0.00</span>}
								</div>
								<div class="occ-place">{divisionRank(r.division, place) || '—'}</div>
							</article>
						);
					})}
				</Fragment>
			))}
		</div>
	</section>
</Layout>

<style>
	.sub-tag { margin-top: 0.5rem; }

	.track { min-width: 0; }
	.track-head { display: flex; align-items: center; gap: 0.85rem; margin-bottom: 0.4rem; }
	.track-head h2 { margin: 0; font-family: var(--font-display); font-weight: 400; font-size: 1.8rem; letter-spacing: 0.04em; }
	.track-head h2 a { color: var(--text); }
	.track-head h2 a:hover { color: var(--swim); text-decoration: none; }
	.track-count { font-family: var(--font-mono); font-size: var(--fs-chip); letter-spacing: var(--ls-wide); text-transform: uppercase; color: var(--faint); }

	/* One swimmer's progression, grouped by year (newest first). Rows mirror the feed
	   .results anatomy: date rail · meet name · right-aligned time (+ delta) · standing,
	   so a swim row reads the same as a tri/run row. */
	.occ-list { display: grid; grid-template-columns: 86px minmax(0, 1fr) max-content max-content; row-gap: 0.6rem; }
	.occ {
		grid-column: 1 / -1; display: grid; grid-template-columns: subgrid; align-items: stretch;
		background: linear-gradient(180deg, var(--surface-2), var(--surface) 80px);
		border: 1px solid var(--border); border-radius: 13px; box-shadow: var(--shadow); overflow: hidden;
	}
	.occ.is-best { border-color: color-mix(in srgb, var(--gold) 50%, var(--border)); box-shadow: var(--shadow), 0 0 0 1px color-mix(in srgb, var(--gold) 40%, transparent); }

	.occ-meet { display: flex; flex-direction: column; justify-content: center; padding: 0.6rem 1.1rem; min-width: 0; }
	.occ-name { font-family: var(--font-display); font-weight: 400; font-size: 1.2rem; letter-spacing: 0.02em; line-height: 1; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	.occ-name:hover { color: var(--swim); text-decoration: none; }

	.occ-time { display: flex; flex-direction: column; align-items: flex-end; justify-content: center; gap: 0.15rem; padding: 0.6rem 1.1rem; }
	.occ-timewrap { position: relative; width: max-content; display: flex; align-items: center; }
	.occ-t { font-family: var(--font-display); font-weight: 400; font-size: 1.6rem; letter-spacing: 0.02em; line-height: 1; white-space: nowrap; }
	.occ-t.is-best { color: var(--gold); }
	.occ-dq { font-family: var(--font-display); font-weight: 400; font-size: 1.6rem; letter-spacing: 0.02em; line-height: 1; color: var(--slower); }
	.delta { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; white-space: nowrap; }
	.delta.faster { color: var(--faster); }
	.delta.slower { color: var(--slower); }
	.delta.same { color: var(--faint); }

	.occ-place { display: flex; align-items: center; justify-content: flex-end; padding: 0.6rem 1.2rem 0.6rem 0.6rem; font-family: var(--font-mono); font-size: var(--fs-value); font-weight: 600; white-space: nowrap; }
</style>
