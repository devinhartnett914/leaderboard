---
// TEST / COMPARISON PAGE (not linked in nav). A matrix to pick the card anatomy:
//   • position: type · racer ABOVE the race name (current) vs BELOW it (proposed)
//   • casing:   the multi-race ROW labels — swim event names + finisher names — ALL-CAPS
//               (current) vs Title Case. The race type/distance tag, race name, meta-band
//               racer, and "N Racers" count always stay uppercase.
// Position uses each card's `metaBelow` prop (keeps single-row data centered, adds room
// under the meta in combined cards). Casing is just CSS — the row labels are already stored
// title case, so the `.tc` section drops `text-transform: uppercase` off the swim event
// labels (mc-evname) and the finisher names (.pchip.plain) only. Delete once decided.
import Layout from '../layouts/Layout.astro';
import ResultRow from '../components/ResultRow.astro';
import MeetCard from '../components/MeetCard.astro';
import RaceGroupCard from '../components/RaceGroupCard.astro';
import { getAllFamilyResults } from '../lib/queries';
import { buildEntries, buildPrContext, award } from '../lib/feed';

const results = await getAllFamilyResults();
const prCtx = buildPrContext(results);
const entries = buildEntries(results, { groupRaces: true });

// one of each shape: a single result with leg splits (tri), a combined multi-family race,
// and a swim meet — so the discipline tag, names, and sub-rows are all represented.
const single = entries.find((e) => e.type === 'card' && (e.r.split?.length ?? 0) > 0)
	?? entries.find((e) => e.type === 'card');
const group = entries.find((e) => e.type === 'race');
const meet = entries.find((e) => e.type === 'meet');
const picks = [single, group, meet].filter((e): e is NonNullable<typeof e> => !!e);

const cases = [
	{ tc: false, label: 'Row labels ALL-CAPS — current' },
	{ tc: true, label: 'Table rows Title Case (finishers + swim events) — header racer + tags stay caps' },
];
const positions = [
	{ below: false, label: 'Type · racer ABOVE the name' },
	{ below: true, label: 'Type · racer BELOW the name' },
];
---
<Layout title="Card layout test" subtitle="Type · racer placement + casing of the discipline & names">
	{cases.map(({ tc, label: caseLabel }) => (
		<section class:list={['case', { tc }]}>
			<h2 class="case-h">{caseLabel}</h2>
			<div class="compare">
				{positions.map(({ below, label }) => (
					<div class="col">
						<h3 class="col-h">{label}</h3>
						<div class="results">
							{picks.map((it) =>
								it.type === 'meet' ? (
									<MeetCard entry={it} prCtx={prCtx} showPerson metaBelow={below} />
								) : it.type === 'race' ? (
									<RaceGroupCard entry={it} prCtx={prCtx} metaBelow={below} />
								) : (
									<ResultRow r={it.r} pr={prCtx.prBadge(it.r)} aw={award(it.r)} showPerson metaBelow={below} />
								),
							)}
						</div>
					</div>
				))}
			</div>
		</section>
	))}
</Layout>

<style>
	/* each case section breaks out of the 1040px column so both positions get a full card */
	.case { width: 94vw; margin-left: calc(50% - 47vw); margin-bottom: 3.5rem; }
	.case-h { font-family: var(--font-display); font-weight: 400; font-size: 1.7rem; letter-spacing: 0.03em; color: var(--accent); margin: 0 0 1.2rem; }
	.compare { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; }
	.col-h {
		font-family: var(--font-mono); font-size: var(--fs-chip); letter-spacing: var(--ls-wide);
		text-transform: uppercase; color: var(--muted); margin: 0 0 1.1rem;
		padding-bottom: 0.6rem; border-bottom: 1px solid var(--border);
	}

	/* Title-case sections, by WHERE the text sits:
	     • in the multi-racer TABLE (finisher rows + swim event rows) → title case
	     • a person's name in the card HEADER (the racer next to the type tag, under the race
	       title), the type/distance tag, and the race name → stay uppercase
	   The table labels are stored title case, so we just drop the uppercase transform.
	   !important to beat the components' own scoped rules (test page only). */
	.case.tc :global(.pchip.plain),
	.case.tc :global(.mc-evname .ev-lbl) { text-transform: none !important; }

	/* stack on narrow screens so the cards never get crushed */
	@media (max-width: 1000px) {
		.case { width: 100%; margin-left: 0; }
		.compare { grid-template-columns: 1fr; gap: 2rem; }
	}
</style>
