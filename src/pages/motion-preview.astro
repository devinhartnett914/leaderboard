---
// THROWAWAY preview — compare page-load animation options for DEV-14. Each variant
// runs the same mock rows; hit Replay to see it again. Pure CSS animation + a tiny
// DOM script just to re-trigger. The LIVE site is unchanged (Layout still uses the
// current gentle fade) — pick one and I'll wire it into Layout.astro, then delete this.
import Layout from '../layouts/Layout.astro';

const variants = [
	{ key: 'subtle', title: 'A · Subtle stagger', note: 'rise 6px · 60ms apart · ~0.4s — quiet; you notice it once, not every visit' },
	{ key: 'cascade', title: 'B · Bigger cascade', note: 'rise 14px · 90ms apart · ~0.7s — a clear top-to-bottom reveal' },
	{ key: 'fade', title: 'C · Page fade-up', note: 'whole page fades up together, no per-row stagger — most restrained' },
];
const rows = ['Page header', 'Card one', 'Card two', 'Card three', 'Card four'];
---

<Layout title="Motion — page-load options">
	<p class="lead muted">Three page-load treatments on the same mock rows. Hit <strong>Replay</strong> to run each
		again. The live site still uses the current gentle fade — tell me which you want and I'll wire it in
		(it respects reduced-motion in every case).</p>

	{variants.map((v) => (
		<section class="mblock">
			<div class="mhead">
				<h2>{v.title}</h2>
				<button class="replay" type="button" data-target={v.key}>↻ Replay</button>
			</div>
			<p class="mnote">{v.note}</p>
			<div class={`rows v-${v.key}`} id={`rows-${v.key}`}>
				{rows.map((label, i) => (
					<div class:list={['mrow', { 'is-head': i === 0 }]} style={`--i:${i}`}>{label}</div>
				))}
			</div>
		</section>
	))}
</Layout>

<style>
	.lead { max-width: 62ch; margin: 0 0 2rem; }
	.mblock { margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
	.mhead { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
	.mhead h2 { margin: 0; font-family: var(--font-display); font-weight: 400; font-size: 1.7rem; letter-spacing: 0.04em; }
	.replay { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); background: none; border: 1px solid var(--border); border-radius: 999px; padding: 0.3rem 0.85rem; cursor: pointer; }
	.replay:hover { border-color: var(--accent); }
	.mnote { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.04em; color: var(--faint); margin: 0.3rem 0 1.1rem; }

	.rows { display: flex; flex-direction: column; gap: 0.7rem; }
	.mrow { background: linear-gradient(180deg, var(--surface-2), var(--surface)); border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: 12px; padding: 1rem 1.2rem; font-family: var(--font-mono); font-size: 0.8rem; color: var(--muted); box-shadow: var(--shadow); }
	.mrow.is-head { border-left-color: var(--gold); font-family: var(--font-display); font-size: 1.4rem; letter-spacing: 0.03em; color: var(--text); }

	/* Rows sit pre-animation (hidden); they animate in only when .play is on the
	   container — added on load and re-toggled by Replay. */
	.rows .mrow { opacity: 0; }
	.rows.play .mrow { animation: mrise var(--dur) ease-out both; animation-delay: calc(var(--i) * var(--stagger)); }

	.v-subtle  { --rise: 6px;  --dur: 0.32s; --stagger: 0.06s; }
	.v-cascade { --rise: 14px; --dur: 0.5s;  --stagger: 0.09s; }
	.v-fade    { --rise: 8px;  --dur: 0.45s; --stagger: 0s; }

	@keyframes mrise {
		from { opacity: 0; transform: translateY(var(--rise)); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@media (prefers-reduced-motion: reduce) {
		.rows .mrow, .rows.play .mrow { opacity: 1 !important; animation: none !important; }
	}
</style>

<script>
	// Add .play on load (each variant animates once) and re-trigger on Replay by
	// toggling the class with a forced reflow. No framework — plain DOM.
	function play(el: Element) {
		el.classList.remove('play');
		void (el as HTMLElement).offsetWidth; // reflow so the animation restarts
		el.classList.add('play');
	}
	document.querySelectorAll('.rows').forEach((el) => play(el));
	document.querySelectorAll('.replay').forEach((btn) => {
		btn.addEventListener('click', () => {
			const key = (btn as HTMLElement).dataset.target;
			const target = document.getElementById('rows-' + key);
			if (target) play(target);
		});
	});
</script>
