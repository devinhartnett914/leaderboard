# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# --- Supabase (create a free project at https://supabase.com) ---
# Project Settings -> Data API -> Project URL
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
# Project Settings -> API Keys -> anon / public key (safe to expose to the browser)
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Project Settings -> API Keys -> service_role key (SERVER ONLY — full admin access, never expose)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Anthropic (for scraping/extraction) ---
# https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# --- Admin ---
# Secret that gates the /api/import write endpoint (sent as the x-admin-token
# header). Generate a random value. If unset, the import endpoint refuses all requests.
ADMIN_TOKEN="a-long-random-string"
